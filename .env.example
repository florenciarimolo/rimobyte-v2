# Copiar a .env y rellenar con valores reales (no commitear .env).
# Sin estas variables el sitio arranca; contacto y reseñas quedan deshabilitados.

# Resend — https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Google reCAPTCHA v3 — https://www.google.com/recaptcha/admin
RECAPTCHA_SITE_KEY=6Lxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RECAPTCHA_SECRET_KEY=6Lxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google Places API — reseñas en la home + aggregateRating en JSON-LD (home / sobre-mí)
# Place ID: https://developers.google.com/maps/documentation/places/web-service/place-id
GOOGLE_PLACES_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_PLACES_PLACE_ID=ChIJxxxxxxxxxxxxxxxxxxxxxxxx

# Opcional — URLs públicas para schema.org sameAs (Person / LocalBusiness)
# Recomendado en producción (Vercel): PUBLIC_LINKEDIN_URL y PUBLIC_GBP_URL refuerzan
# la señal de entidad en Google y el enlace a reseñas en testimonios.
# PUBLIC_INSTAGRAM_URL=https://www.instagram.com/tu_usuario
# PUBLIC_LINKEDIN_URL=https://www.linkedin.com/in/florencia-rimolofigueira
# PUBLIC_GBP_URL=https://maps.app.goo.gl/xxxx
