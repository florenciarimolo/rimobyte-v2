---
import Base from '../layouts/Base.astro';
import Navbar from '../components/sections/Navbar.astro';
import SectorBreadcrumb from '../components/sections/sector/SectorBreadcrumb.astro';
import HeroSectorV6 from '../components/sections/sector/HeroSectorV6.astro';
import SectorHonestV6 from '../components/sections/sector/SectorHonestV6.astro';
import SectorConceptV6 from '../components/sections/sector/SectorConceptV6.astro';
import SectorFeaturesV6 from '../components/sections/sector/SectorFeaturesV6.astro';
import ProyectosRelacionadosServicio from '../components/sections/servicios/ProyectosRelacionadosServicio.astro';
import OfertaSector from '../components/sections/sector/OfertaSector.astro';
import FAQ from '../components/sections/FAQ.astro';
import Footer from '../components/sections/Footer.astro';
import { sectors } from '../data/sectors';

const sector = sectors.find((s) => s.slug === 'web-para-inmobiliarias')!;

const sectorUrl = new URL('/web-para-inmobiliarias/', Astro.site).href;
const sectorLdGraph = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'FAQPage',
      mainEntity: sector.faqs.map((faq) => ({
        '@type': 'Question',
        name: faq.question,
        acceptedAnswer: { '@type': 'Answer', text: faq.answer },
      })),
    },
    {
      '@type': 'Service',
      name: 'Diseño web para inmobiliarias',
      provider: { '@type': 'Person', name: 'Flor Rímolo', url: 'https://rimobyte.com/' },
      areaServed: { '@type': 'Country', name: 'España' },
      description: sector.seo.description,
      offers: {
        '@type': 'Offer',
        priceCurrency: 'EUR',
        price: '1200',
        priceSpecification: { '@type': 'PriceSpecification', minPrice: '1200', priceCurrency: 'EUR' },
      },
      url: sectorUrl,
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        {
          '@type': 'ListItem',
          position: 1,
          name: 'Inicio',
          item: new URL('/', Astro.site).href,
        },
        {
          '@type': 'ListItem',
          position: 2,
          name: 'Servicios',
          item: new URL('/servicios/', Astro.site).href,
        },
        {
          '@type': 'ListItem',
          position: 3,
          name: 'Web para inmobiliarias',
          item: sectorUrl,
        },
      ],
    },
  ],
};
---

<Base title={sector.seo.title} description={sector.seo.description}>
  <script slot="head" is:inline type="application/ld+json" set:html={JSON.stringify(sectorLdGraph)} />

  <Navbar />
  <main id="main">
    <SectorBreadcrumb />
    <HeroSectorV6 sector={sector} />
    {sector.painPoints?.credentials && <SectorHonestV6 painPoints={sector.painPoints} />}
    {sector.concept && <SectorConceptV6 concept={sector.concept} />}
    <SectorFeaturesV6
      eyebrow={sector.featuresEyebrow}
      title={sector.featuresTitle}
      titleEm={sector.featuresTitleEm}
      intro={sector.featuresIntro}
      features={sector.features}
    />
    {
      sector.relatedProjects && (
        <ProyectosRelacionadosServicio
          eyebrow={sector.relatedProjects.eyebrow}
          title={sector.relatedProjects.title}
          titleEm={sector.relatedProjects.titleEm}
          intro={sector.relatedProjects.intro}
          slugs={sector.relatedProjects.slugs}
        />
      )
    }
    {sector.offer && <OfertaSector offer={sector.offer} />}
    <FAQ
      faqs={sector.faqs}
      title={sector.faqTitle ?? 'Dudas habituales antes de'}
      titleGradient={sector.faqTitleEm ?? 'empezar.'}
      subtitle=""
    />
  </main>
  <Footer />
</Base>
