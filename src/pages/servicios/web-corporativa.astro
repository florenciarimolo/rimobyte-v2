---
import Base from '../../layouts/Base.astro';
import Navbar from '../../components/sections/Navbar.astro';
import HeroServicio from '../../components/sections/servicios/HeroServicio.astro';
import ParaQuienEs from '../../components/sections/servicios/ParaQuienEs.astro';
import QueIncluye from '../../components/sections/servicios/QueIncluye.astro';
import PrecioServicio from '../../components/sections/servicios/PrecioServicio.astro';
import CasosRelacionados from '../../components/sections/servicios/CasosRelacionados.astro';
import OtrosServicios from '../../components/sections/servicios/OtrosServicios.astro';
import CTAFinalServicio from '../../components/sections/servicios/CTAFinalServicio.astro';
import ContactFormIsland from '../../components/sections/ContactFormIsland.astro';
import FAQ from '../../components/sections/FAQ.astro';
import Footer from '../../components/sections/Footer.astro';
import { services } from '../../data/services';

const service = services.find((s) => s.slug === 'web-corporativa')!;

const serviceUrl = new URL(`/servicios/${service.slug}/`, Astro.site).href;
const servicesHubUrl = new URL('/servicios/', Astro.site).href;

const serviceLdGraph = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'FAQPage',
      mainEntity: service.faqs.map((faq) => ({
        '@type': 'Question',
        name: faq.question,
        acceptedAnswer: { '@type': 'Answer', text: faq.answer },
      })),
    },
    {
      '@type': 'Service',
      name: 'Web corporativa para negocios locales',
      provider: { '@type': 'Person', name: 'Flor Rímolo', url: 'https://rimobyte.com/' },
      areaServed: { '@type': 'Country', name: 'España' },
      description: service.seo.description,
      offers: {
        '@type': 'Offer',
        priceCurrency: 'EUR',
        price: '600',
        priceSpecification: { '@type': 'PriceSpecification', minPrice: '600', priceCurrency: 'EUR' },
      },
      url: serviceUrl,
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        {
          '@type': 'ListItem',
          position: 1,
          name: 'Inicio',
          item: new URL('/', Astro.site).href,
        },
        {
          '@type': 'ListItem',
          position: 2,
          name: 'Servicios',
          item: servicesHubUrl,
        },
        {
          '@type': 'ListItem',
          position: 3,
          name: service.name,
          item: serviceUrl,
        },
      ],
    },
  ],
};
---

<Base title={service.seo.title} description={service.seo.description}>
  <script slot="head" is:inline type="application/ld+json" set:html={JSON.stringify(serviceLdGraph)} />

  <Navbar />
  <main id="main">
    <HeroServicio service={service} />
    <ParaQuienEs points={service.targetAudience} />
    <QueIncluye features={service.features} />
    <PrecioServicio price={service.price} note={service.priceNote} />
    <CasosRelacionados
      cases={service.relatedCases}
      title={service.relatedCasesTitle}
      titleEm={service.relatedCasesTitleEm}
    />
    <FAQ faqs={service.faqs} />
    <OtrosServicios currentSlug={service.slug} />
    <CTAFinalServicio
      title={service.ctaFinal.title}
      titleEm={service.ctaFinal.titleEm}
      text={service.ctaFinal.text}
    />
    <ContactFormIsland origin="web-corporativa" omitAnchor />
  </main>
  <Footer />
</Base>
