---
import Base from '../../layouts/Base.astro';
import Navbar from '../../components/sections/Navbar.astro';
import Footer from '../../components/sections/Footer.astro';
import HeroServiciosHub from '../../components/sections/servicios/HeroServiciosHub.astro';
import ServicesHubGrid from '../../components/sections/servicios/ServicesHubGrid.astro';
import DecisionServicios from '../../components/sections/servicios/DecisionServicios.astro';
import VerticalesServicios from '../../components/sections/servicios/VerticalesServicios.astro';
import ProcesoServicio from '../../components/sections/servicios/ProcesoServicio.astro';
import FAQ from '../../components/sections/FAQ.astro';
import HomeCTA from '../../components/sections/HomeCTA.astro';
import { hubFaqs, serviceProcessSteps } from '../../data/servicesHub';

const SEO = {
  title: 'Servicios de diseño web para negocios locales · RimoByte',
  description:
    'Web corporativa, tienda online y mantenimiento web para autónomos y negocios locales. Presupuesto cerrado, tuya desde el primer día.',
};

const servicesUrl = new URL('/servicios/', Astro.site).href;

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: new URL('/', Astro.site).href },
    { '@type': 'ListItem', position: 2, name: 'Servicios', item: servicesUrl },
  ],
};
---

<Base title={SEO.title} description={SEO.description}>
  <script slot="head" is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />

  <Navbar />
  <main id="main" class="services-hub-v6">
    <HeroServiciosHub />
    <ServicesHubGrid />
    <DecisionServicios />
    <VerticalesServicios />
    <ProcesoServicio
      centered
      title="El mismo proceso en"
      titleEm="cada proyecto."
      description="No porque sea una norma — porque funciona. Cinco pasos sin sorpresas, con presupuesto cerrado y sin que tengas que perseguir nada."
      steps={serviceProcessSteps}
    />
    <FAQ
      faqs={hubFaqs}
      title="Sobre presupuestos, plazos y"
      titleGradient="qué incluye cada cosa."
      subtitle=""
    />
    <HomeCTA />
  </main>
  <Footer />
</Base>
