---
import Base from '../layouts/Base.astro';
import Navbar from '../components/sections/Navbar.astro';
import HeroSector from '../components/sections/sector/HeroSector.astro';
import PorQueSector from '../components/sections/sector/PorQueSector.astro';
import QueNecesitaSector from '../components/sections/sector/QueNecesitaSector.astro';
import CasoSector from '../components/sections/sector/CasoSector.astro';
import ContactFormIsland from '../components/sections/ContactFormIsland.astro';
import FAQ from '../components/sections/FAQ.astro';
import Footer from '../components/sections/Footer.astro';
import { sectors } from '../data/sectors';

const sector = sectors.find((s) => s.slug === 'web-para-restaurantes')!;

const sectorUrl = new URL('/web-para-restaurantes/', Astro.site).href;
const sectorLdGraph = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'FAQPage',
      mainEntity: sector.faqs.map((faq) => ({
        '@type': 'Question',
        name: faq.question,
        acceptedAnswer: { '@type': 'Answer', text: faq.answer },
      })),
    },
    {
      '@type': 'Service',
      name: 'Web para restaurantes y hostelería',
      provider: { '@type': 'Person', name: 'Flor Rímolo', url: 'https://rimobyte.com/' },
      areaServed: { '@type': 'Country', name: 'España' },
      description: sector.seo.description,
      offers: {
        '@type': 'Offer',
        priceCurrency: 'EUR',
        price: '600',
        priceSpecification: { '@type': 'PriceSpecification', minPrice: '600', priceCurrency: 'EUR' },
      },
      url: sectorUrl,
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        {
          '@type': 'ListItem',
          position: 1,
          name: 'Inicio',
          item: new URL('/', Astro.site).href,
        },
        {
          '@type': 'ListItem',
          position: 2,
          name: 'Web para restaurantes',
          item: sectorUrl,
        },
      ],
    },
  ],
};
---

<Base title={sector.seo.title} description={sector.seo.description}>
  <script slot="head" is:inline type="application/ld+json" set:html={JSON.stringify(sectorLdGraph)} />

  <Navbar />
  <main id="main">
    <HeroSector sector={sector} />
    {
      sector.painPoints && (
        <PorQueSector
          eyebrow={sector.painPoints.eyebrow}
          title={sector.painPoints.title}
          titleEm={sector.painPoints.titleEm}
          points={sector.painPoints.points ?? []}
        />
      )
    }
    <QueNecesitaSector
      features={sector.features}
      sectorName={sector.sectorNameShort}
      intro={sector.featuresIntro}
      title={sector.featuresTitle}
      titleEm={sector.featuresTitleEm}
    />
    {sector.relatedCase && <CasoSector caseData={sector.relatedCase} />}
    <FAQ faqs={sector.faqs} />
    <ContactFormIsland
      origin="web-para-restaurantes"
      heading={sector.ctaFinal.title}
      headingEm={sector.ctaFinal.titleEm}
      intro={sector.ctaFinal.text}
      priceNote="Desde 600€ · Presupuesto cerrado"
      serviceLink={sector.serviceLink}
    />
  </main>
  <Footer />
</Base>
