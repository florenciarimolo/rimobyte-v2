---
import Base from '../../layouts/Base.astro';
import Navbar from '../../components/sections/Navbar.astro';
import HeroBlog from '../../components/sections/blog/HeroBlog.astro';
import BlogCategoryFilter from '../../components/sections/blog/BlogCategoryFilter.astro';
import BlogFeatured from '../../components/sections/blog/BlogFeatured.astro';
import BlogGrid from '../../components/sections/blog/BlogGrid.astro';
import Footer from '../../components/sections/Footer.astro';
import { getCollection } from 'astro:content';
import { blogIndexSeo } from '../../data/staticPageSeo';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const [featured, ...rest] = posts;

const blogUrl = new URL('/blog/', Astro.site).href;

const blogIndexLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Blog',
      '@id': `${blogUrl}#blog`,
      name: 'Blog RimoByte',
      url: blogUrl,
      description: blogIndexSeo.description,
      inLanguage: 'es-ES',
      publisher: {
        '@type': 'Organization',
        name: 'RimoByte',
        url: 'https://rimobyte.com/',
      },
      blogPost: posts.map((p) => ({
        '@type': 'BlogPosting',
        headline: p.data.title,
        url: new URL(`/blog/${p.id}/`, Astro.site).href,
        datePublished: p.data.date.toISOString(),
      })),
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        {
          '@type': 'ListItem',
          position: 1,
          name: 'Inicio',
          item: new URL('/', Astro.site).href,
        },
        {
          '@type': 'ListItem',
          position: 2,
          name: 'Blog',
          item: blogUrl,
        },
      ],
    },
  ],
};
---

<Base title={blogIndexSeo.title} description={blogIndexSeo.description}>
  <script slot="head" is:inline type="application/ld+json" set:html={JSON.stringify(blogIndexLd)} />

  <Navbar />
  <main id="main">
    <HeroBlog />
    <BlogCategoryFilter />
    {featured && <BlogFeatured post={featured} />}
    {rest.length > 0 && <BlogGrid posts={rest} />}
  </main>
  <Footer />
</Base>
