---
import Base from '../../layouts/Base.astro';
import Navbar from '../../components/sections/Navbar.astro';
import HeroProyectos from '../../components/sections/proyectos/HeroProyectos.astro';
import PortfolioStats from '../../components/sections/proyectos/PortfolioStats.astro';
import ProjectFilters from '../../components/sections/proyectos/ProjectFilters.astro';
import ProjectsGrid from '../../components/sections/proyectos/ProjectsGrid.astro';
import CTAFinalProyectos from '../../components/sections/proyectos/CTAFinalProyectos.astro';
import Footer from '../../components/sections/Footer.astro';
import { projectCount } from '../../data/projects';
import { proyectosIndexSeo } from '../../data/staticPageSeo';

const seo = proyectosIndexSeo(projectCount);
---

<Base title={seo.title} description={seo.description} image={seo.image}>
  <Navbar />
  <main id="main">
    <HeroProyectos />
    <PortfolioStats />
    <ProjectFilters />
    <ProjectsGrid />
    <CTAFinalProyectos />
  </main>
  <Footer />
</Base>
