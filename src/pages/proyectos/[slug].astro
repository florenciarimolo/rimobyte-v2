---
import Base from '../../layouts/Base.astro';
import Navbar from '../../components/sections/Navbar.astro';
import HeroProyecto from '../../components/sections/proyecto/HeroProyecto.astro';
import StatsProyecto from '../../components/sections/proyecto/StatsProyecto.astro';
import ChallengeApproachOutcome from '../../components/sections/proyecto/ChallengeApproachOutcome.astro';
import TestimonioProyecto from '../../components/sections/proyecto/TestimonioProyecto.astro';
import NextPrevProyecto from '../../components/sections/proyecto/NextPrevProyecto.astro';
import ContactForm from '../../components/sections/ContactForm.tsx';
import Footer from '../../components/sections/Footer.astro';
import {
  projects,
  getNextProject,
  getPrevProject,
  type Project,
} from '../../data/projects';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = () =>
  projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));

interface Props {
  project: Project;
}

const { project } = Astro.props;
const nextProject = getNextProject(project.slug);
const prevProject = getPrevProject(project.slug);

const seoImagePath = project.heroImage ?? project.image;

const articleIsoDate = /^\d{4}-\d{2}$/.test(project.date)
  ? `${project.date}-01`
  : project.date;

const SEO = {
  title: `${project.name} — Caso de éxito · RimoByte`,
  description: `${project.challenge.split('.')[0]?.trim() ?? project.challenge}. ${project.result.split('.')[0]?.trim() ?? project.result}.`,
  image: seoImagePath,
};

const publisherLogoUrl = new URL('/android-chrome-512x512.png', Astro.site).href;

const articleSchema = {
  '@type': 'Article',
  headline: project.displayName,
  description: SEO.description,
  image: new URL(seoImagePath, Astro.site).href,
  datePublished: articleIsoDate,
  dateModified: articleIsoDate,
  author: {
    '@type': 'Person',
    name: 'Flor Rímolo',
    url: 'https://rimobyte.com',
  },
  publisher: {
    '@type': 'Organization',
    name: 'RimoByte',
    url: 'https://rimobyte.com',
    logo: {
      '@type': 'ImageObject',
      url: publisherLogoUrl,
    },
  },
  about: { '@type': 'Thing', name: project.sector },
};

const breadcrumbSchema = {
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Inicio',
      item: new URL('/', Astro.site).href,
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Proyectos',
      item: new URL('/proyectos/', Astro.site).href,
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: project.name,
      item: new URL(`/proyectos/${project.slug}/`, Astro.site).href,
    },
  ],
};

const projectLdGraph = {
  '@context': 'https://schema.org',
  '@graph': [articleSchema, breadcrumbSchema],
};
---

<Base
  title={SEO.title}
  description={SEO.description}
  image={SEO.image}
  ogType="article"
  articlePublishedTime={articleIsoDate}
  articleModifiedTime={articleIsoDate}
>
  <script
    slot="head"
    is:inline
    type="application/ld+json"
    set:html={JSON.stringify(projectLdGraph)}
  />
  <Navbar />
  <main id="main">
    <HeroProyecto project={project} />
    <StatsProyecto stats={project.stats} />
    <ChallengeApproachOutcome project={project} />
    {project.testimonial && (
      <TestimonioProyecto testimonial={project.testimonial} projectUrl={project.url} />
    )}
    <NextPrevProyecto nextProject={nextProject} prevProject={prevProject} />
    <ContactForm client:load />
  </main>
  <Footer />
</Base>
