---
import Base from '../layouts/Base.astro';
import Navbar from '../components/sections/Navbar.astro';
import ContactFormIsland from '../components/sections/ContactFormIsland.astro';
import Footer from '../components/sections/Footer.astro';

const SEO = {
  title: 'Contacto · RimoByte',
  description:
    'Cuéntame tu proyecto y te respondo sin tecnicismos. Diseño y desarrollo web para negocios locales — Flor Rímolo.',
  image: '/assets/brand/flor-rimobyte.webp',
};
---

<Base title={SEO.title} description={SEO.description} image={SEO.image}>
  <Navbar />
  <main id="main">
    <ContactFormIsland />
  </main>
  <Footer />
</Base>
