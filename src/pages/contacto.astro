---
import Base from '../layouts/Base.astro';
import Navbar from '../components/sections/Navbar.astro';
import HeroContacto from '../components/sections/contacto/HeroContacto.astro';
import ContactoGrid from '../components/sections/contacto/ContactoGrid.astro';
import ContactoProceso from '../components/sections/contacto/ContactoProceso.astro';
import FAQ from '../components/sections/FAQ.astro';
import ContactoCTA from '../components/sections/contacto/ContactoCTA.astro';
import Footer from '../components/sections/Footer.astro';
import { contactFaqEntries } from '../data/contacto';
import { buildFaqPageJsonLdFromPairs } from '../data/faq';
import { contactoSeo } from '../data/staticPageSeo';

const contactUrl = new URL('/contacto/', Astro.site).href;

const contactLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'ContactPage',
      name: contactoSeo.title,
      url: contactUrl,
      description: contactoSeo.description,
      inLanguage: 'es-ES',
      mainEntity: {
        '@type': 'Person',
        name: 'Flor Rímolo',
        url: 'https://rimobyte.com/',
        email: 'info@rimobyte.com',
        telephone: '+34684713743',
      },
    },
    buildFaqPageJsonLdFromPairs(
      contactFaqEntries.map(({ q, a }) => ({ name: q, text: a })),
    ),
  ],
};
---

<Base title={contactoSeo.title} description={contactoSeo.description} image={contactoSeo.image}>
  <script slot="head" is:inline type="application/ld+json" set:html={JSON.stringify(contactLd)} />

  <Navbar />
  <main id="main">
    <HeroContacto />
    <ContactoGrid />
    <ContactoProceso />
    <FAQ
      id="faq"
      pill="Antes de escribirme"
      title="Las dudas más habituales"
      titleGradient="en este punto."
      subtitle="Si la tuya no está aquí, escríbeme — sin compromiso."
      faqs={contactFaqEntries}
      openFirst
    />
    <ContactoCTA />
  </main>
  <Footer />
</Base>
