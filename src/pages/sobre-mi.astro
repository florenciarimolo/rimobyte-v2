---
import Base from '../layouts/Base.astro';
import Navbar from '../components/sections/Navbar.astro';
import HeroSobreMi from '../components/sections/sobre-mi/HeroSobreMi.astro';
import Marquee from '../components/sections/Marquee.astro';
import EnQueCreo from '../components/sections/sobre-mi/EnQueCreo.astro';
import MiHistoria from '../components/sections/sobre-mi/MiHistoria.astro';
import ComoTrabajo from '../components/sections/sobre-mi/ComoTrabajo.astro';
import TestimoniosSobreMi from '../components/sections/sobre-mi/TestimoniosSobreMi.astro';
import CTAFinal from '../components/sections/sobre-mi/CTAFinal.astro';
import Footer from '../components/sections/Footer.astro';
import { fetchPlaceAggregate } from '../lib/google-reviews';
import { sobreMiSeo } from '../data/staticPageSeo';

const placeAgg = await fetchPlaceAggregate();
---
<Base
  title={sobreMiSeo.title}
  description={sobreMiSeo.description}
  image={sobreMiSeo.image}
  aggregateRating={placeAgg}
>
  <Navbar />
  <main id="main">
    <HeroSobreMi />
    <Marquee />
    <EnQueCreo />
    <MiHistoria />
    <ComoTrabajo />
    <TestimoniosSobreMi />
    <CTAFinal />
  </main>
  <Footer />
</Base>
