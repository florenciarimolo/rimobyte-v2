---
import Base from '../layouts/Base.astro';
import Navbar from '../components/sections/Navbar.astro';
import Hero from '../components/sections/Hero.astro';
import FeaturedCase from '../components/sections/FeaturedCase.astro';
import Stats from '../components/sections/Stats.astro';
import Features from '../components/sections/Features.astro';
import ProjectsFan from '../components/sections/ProjectsFan.astro';
import PhotoStatement from '../components/sections/PhotoStatement.astro';
import Testimonials from '../components/sections/Testimonials.astro';
import Services from '../components/sections/Services.astro';
import FAQ from '../components/sections/FAQ.astro';
import ContactFormIsland from '../components/sections/ContactFormIsland.astro';
import Footer from '../components/sections/Footer.astro';
import { buildFaqPageJsonLd } from '../data/faq';
import { fetchPlaceAggregate } from '../lib/google-reviews';

const SEO = {
  title: 'Diseñadora web freelance para negocios locales · RimoByte',
  description: 'Soy Flor, ingeniera informática. Creo webs para negocios locales con acompañamiento real y sin letra pequeña — tuya desde el primer día.',
  image: '/assets/brand/flor-rimobyte.webp',
};

const placeAgg = await fetchPlaceAggregate();
---
<Base
  title={SEO.title}
  description={SEO.description}
  image={SEO.image}
  faqPageSchema={buildFaqPageJsonLd()}
  aggregateRating={placeAgg}
>
  <Navbar />
  <main id="main">
    <Hero />
    <FeaturedCase />
    <Stats />
    <Features />
    <PhotoStatement />
    <Testimonials />
    <ProjectsFan />
    <Services />
    <FAQ />
    <ContactFormIsland />
  </main>
  <Footer />
</Base>
