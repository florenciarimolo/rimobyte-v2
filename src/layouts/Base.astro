---
import '../styles/global.css';
import PageLoader from '../components/ui/PageLoader.astro';
import SiteBackground from '../components/ui/SiteBackground.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  noindex?: boolean;
}

const {
  title = 'RimoByte — Diseño web para negocios locales',
  description = 'Flor Rímolo, ingeniera informática freelance. Webs para negocios locales con acompañamiento real y sin letra pequeña.',
  image = '/assets/brand/flor-rimobyte.webp',
  noindex = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(image, Astro.site);

const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'LocalBusiness',
      '@id': 'https://rimobyte.com/#business',
      name: 'RimoByte',
      url: 'https://rimobyte.com',
      email: 'info@rimobyte.com',
      telephone: '+34684713743',
      image: 'https://rimobyte.com/assets/brand/flor-rimobyte.webp',
      description,
      founder: { '@id': 'https://rimobyte.com/#person' },
      areaServed: { '@type': 'Country', name: 'España' },
    },
    {
      '@type': 'Person',
      '@id': 'https://rimobyte.com/#person',
      name: 'Flor Rímolo',
      jobTitle: 'Ingeniera informática freelance',
      url: 'https://rimobyte.com',
      email: 'info@rimobyte.com',
      image: 'https://rimobyte.com/assets/brand/flor-rimobyte.webp',
      worksFor: { '@id': 'https://rimobyte.com/#business' },
    },
  ],
};
---
<!doctype html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  {noindex && <meta name="robots" content="noindex, nofollow" />}
  <link rel="canonical" href={canonicalURL} />
  <title>{title}</title>

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:locale" content="es_ES" />
  <meta property="og:site_name" content="RimoByte" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:image" content={ogImageURL} />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageURL} />

  <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)} />

  <link rel="icon" href="/favicon.ico" sizes="48x48" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/site.webmanifest" />
  <meta name="theme-color" content="#0A0A12" />

  <!-- Clash Grotesk — Fontshare CDN (no disponible en Fontsource) -->
  <link rel="preconnect" href="https://api.fontshare.com" />
  <link
    href="https://api.fontshare.com/v2/css?f[]=clash-grotesk@400,500,600,700&display=swap"
    rel="stylesheet"
  />

  <!-- Space Mono — Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Mono&display=swap" rel="stylesheet" />
</head>
<body class="is-loading">
  <a href="#main" class="skip-link">Saltar al contenido</a>
  <PageLoader />
  <SiteBackground />
  <slot />

  <script>
    import '../scripts/interactive-dots.ts';
  </script>
  <script>
    const io = new IntersectionObserver(
      es => es.forEach(e => {
        if (e.isIntersecting) { e.target.classList.add('visible'); io.unobserve(e.target); }
      }),
      { threshold: 0.08, rootMargin: '0px 0px -40px 0px' }
    );
    document.querySelectorAll('.reveal').forEach(el => io.observe(el));
  </script>
</body>
</html>
