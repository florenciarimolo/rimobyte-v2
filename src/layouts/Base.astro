---
import '../styles/global.css';
import CookieBanner from '../components/ui/CookieBanner.astro';
import PageLoader from '../components/ui/PageLoader.astro';
import { resolveOgImage } from '../lib/og/url';
import { publicProfileUrls } from '../lib/site';
import { canonicalPath } from '../lib/url';
import { defaultBaseSeo } from '../data/staticPageSeo';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  noindex?: boolean;
  ogType?: 'website' | 'article';
  articlePublishedTime?: string;
  articleModifiedTime?: string;
  /** Solo home — FAQPage JSON-LD */
  faqPageSchema?: Record<string, unknown> | null;
  /** Person + LocalBusiness — desde Google Places cuando hay API configurada */
  aggregateRating?: { ratingValue: number; reviewCount: number } | null;
}

const {
  title = defaultBaseSeo.title,
  description = defaultBaseSeo.description,
  image = defaultBaseSeo.image ?? '/assets/brand/flor-rimobyte.webp',
  noindex = false,
  ogType = 'website',
  articlePublishedTime,
  articleModifiedTime,
  faqPageSchema = null,
  aggregateRating = null,
} = Astro.props;

const canonicalPathname = canonicalPath(Astro.url.pathname);
const canonicalURL = new URL(canonicalPathname, Astro.site);
const ogImagePath = resolveOgImage({
  image,
  pathname: canonicalPathname,
});
const ogImageUrl = new URL(ogImagePath, Astro.site).href;

const pathNorm = Astro.url.pathname.replace(/\/+$/, '') || '/';
const isPersonalPage = pathNorm === '/' || pathNorm === '/sobre-mi';

const sameAs = publicProfileUrls();

const personBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': ['Person', 'LocalBusiness'],
  name: 'Flor Rímolo',
  jobTitle: 'Desarrolladora web WordPress freelance — Ingeniera informática',
  url: 'https://rimobyte.com',
  email: 'info@rimobyte.com',
  telephone: '+34684713743',
  description: 'Ingeniera informática especializada en desarrollo web para negocios locales.',
  areaServed: {
    '@type': 'Country',
    name: 'España',
  },
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Barcelona',
    addressCountry: 'ES',
  },
  priceRange: 'EUR',
  openingHours: 'Mo-Fr 09:00-18:00',
  image: 'https://rimobyte.com/assets/brand/flor-rimobyte.webp',
  ...(aggregateRating &&
    aggregateRating.reviewCount > 0 && {
      aggregateRating: {
        '@type': 'AggregateRating',
        ratingValue: String(aggregateRating.ratingValue),
        reviewCount: String(aggregateRating.reviewCount),
        bestRating: '5',
        worstRating: '1',
      },
    }),
  ...(sameAs.length > 0 && { sameAs }),
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'RimoByte',
  url: 'https://rimobyte.com',
  inLanguage: 'es-ES',
  description:
    'Desarrollo web WordPress para negocios locales. Webs profesionales tuyas desde el primer día.',
  author: {
    '@type': 'Person',
    name: 'Flor Rímolo',
  },
};

const structuredData = isPersonalPage ? personBusinessSchema : websiteSchema;
---
<!doctype html>
<html lang="es" class="site-layout">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <meta name="apple-mobile-web-app-status-bar-style" content="default" />
  <meta name="description" content={description} />
  {noindex ? (
    <meta name="robots" content="noindex, nofollow" />
  ) : (
    <meta name="robots" content="index, follow, max-image-preview:large" />
  )}
  <title>{title}</title>

  <!-- Open Graph -->
  <meta property="og:type" content={ogType} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImageUrl} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:locale" content="es_ES" />
  <meta property="og:site_name" content="RimoByte" />
  <meta property="og:url" content={canonicalURL.href} />
  {ogType === 'article' && articlePublishedTime && (
    <meta property="article:published_time" content={articlePublishedTime} />
  )}
  {ogType === 'article' && articleModifiedTime && (
    <meta property="article:modified_time" content={articleModifiedTime} />
  )}

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageUrl} />

  <!-- Canonical -->
  <link rel="canonical" href={canonicalURL.href} />

  <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)}></script>
  {faqPageSchema && (
    <script is:inline type="application/ld+json" set:html={JSON.stringify(faqPageSchema)}></script>
  )}
  <slot name="head" />

  <link rel="icon" href="/favicon.ico" sizes="48x48" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/site.webmanifest" />
  <meta name="theme-color" content="#FAFAFC" />
  <meta name="theme-color" id="theme-color-meta" content="#FAFAFC" />

  <script is:inline>
    (function () {
      document.documentElement.dataset.theme = 'light';
      document.documentElement.style.colorScheme = 'light';
    })();
  </script>
</head>
<body class="is-loading site-layout">
  <svg width="0" height="0" style="position:absolute" aria-hidden="true">
    <defs>
      <linearGradient id="starGrad" x1="0" y1="0" x2="1" y2="1">
        <stop offset="0%" stop-color="#196BEE" />
        <stop offset="50%" stop-color="#6535E5" />
        <stop offset="100%" stop-color="#E715D1" />
      </linearGradient>
    </defs>
  </svg>
  <a href="#main" class="skip-link">Saltar al contenido</a>
  <div class="aurora-bg" aria-hidden="true"></div>
  <PageLoader />
  <slot />
  <CookieBanner />

  <script>
    import '../scripts/site.ts';
  </script>
  <script>
    const io = new IntersectionObserver(
      es => es.forEach(e => {
        if (e.isIntersecting) { e.target.classList.add('visible'); io.unobserve(e.target); }
      }),
      { threshold: 0.08, rootMargin: '0px 0px -40px 0px' }
    );
    document.querySelectorAll('.reveal').forEach(el => io.observe(el));
    document.addEventListener('astro:hydrate', () => {
      document.querySelectorAll('.reveal:not(.visible)').forEach(el => io.observe(el));
    });
  </script>

  <div id="recaptcha-root" aria-hidden="true"></div>
</body>
</html>
