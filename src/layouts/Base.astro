---
import '../styles/global.css';
import PageLoader from '../components/ui/PageLoader.astro';
import SiteBackground from '../components/ui/SiteBackground.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  noindex?: boolean;
  ogType?: 'website' | 'article';
  articlePublishedTime?: string;
  articleModifiedTime?: string;
  /** Solo home — FAQPage JSON-LD */
  faqPageSchema?: Record<string, unknown> | null;
}

const {
  title = 'Diseñadora web freelance para negocios locales · RimoByte',
  description = 'Soy Flor, ingeniera informática especializada en desarrollo web. Creo webs para negocios locales con acompañamiento real y sin letra pequeña — tuya desde el primer día.',
  image = '/assets/brand/flor-rimobyte.webp',
  noindex = false,
  ogType = 'website',
  articlePublishedTime,
  articleModifiedTime,
  faqPageSchema = null,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

// Detectar si es home o sobre-mi para usar schema Person + LocalBusiness
const isPersonalPage = Astro.url.pathname === '/' || Astro.url.pathname === '/sobre-mi/' || Astro.url.pathname === '/sobre-mi';

// Schema: Person + LocalBusiness (para home y sobre-mi)
const personBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': ['Person', 'LocalBusiness'],
  name: 'Flor Rímolo',
  jobTitle: 'Diseñadora web freelance — Ingeniera informática',
  url: 'https://rimobyte.com',
  email: 'info@rimobyte.com',
  telephone: '+34684713743',
  description: 'Ingeniera informática especializada en desarrollo web para negocios locales.',
  areaServed: {
    '@type': 'Country',
    name: 'España',
  },
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Barcelona',
    addressCountry: 'ES',
  },
  priceRange: 'EUR',
  openingHours: 'Mo-Fr 09:00-18:00',
  image: 'https://rimobyte.com/assets/brand/flor-rimobyte.webp',
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '5',
    reviewCount: '10',
    bestRating: '5',
    worstRating: '5',
  },
};

// Schema: WebSite + SearchAction del blog (plantilla q= cuando exista la ruta /blog)
const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'RimoByte',
  url: 'https://rimobyte.com',
  description: 'Diseño web freelance para negocios locales. Webs profesionales tuyas desde el primer día.',
  author: {
    '@type': 'Person',
    name: 'Flor Rímolo',
  },
  potentialAction: {
    '@type': 'SearchAction',
    target: {
      '@type': 'EntryPoint',
      urlTemplate: 'https://rimobyte.com/blog?q={search_term_string}',
    },
    'query-input': 'required name=search_term_string',
  },
};

// Seleccionar schema según la página
const structuredData = isPersonalPage ? personBusinessSchema : websiteSchema;
---
<!doctype html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  {noindex ? (
    <meta name="robots" content="noindex, nofollow" />
  ) : (
    <meta name="robots" content="index, follow, max-image-preview:large" />
  )}
  <title>{title}</title>

  <!-- Open Graph -->
  <meta property="og:type" content={ogType} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={new URL(image, Astro.site).href} />
  <meta property="og:locale" content="es_ES" />
  <meta property="og:site_name" content="RimoByte" />
  <meta property="og:url" content={canonicalURL.href} />
  {ogType === 'article' && articlePublishedTime && (
    <meta property="article:published_time" content={articlePublishedTime} />
  )}
  {ogType === 'article' && articleModifiedTime && (
    <meta property="article:modified_time" content={articleModifiedTime} />
  )}

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={new URL(image, Astro.site).href} />

  <!-- Canonical -->
  <link rel="canonical" href={canonicalURL.href} />

  <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)}></script>
  {faqPageSchema && (
    <script is:inline type="application/ld+json" set:html={JSON.stringify(faqPageSchema)}></script>
  )}
  <slot name="head" />

  <link rel="icon" href="/favicon.ico" sizes="48x48" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/site.webmanifest" />
  <meta name="theme-color" content="#0A0A12" />

  <!-- Clash Grotesk — Fontshare CDN (no disponible en Fontsource) -->
  <link rel="preconnect" href="https://api.fontshare.com" />
  <link
    href="https://api.fontshare.com/v2/css?f[]=clash-grotesk@400,500,600,700&display=swap"
    rel="stylesheet"
  />

  <!-- Space Mono — Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Mono&display=swap" rel="stylesheet" />
</head>
<body class="is-loading">
  <a href="#main" class="skip-link">Saltar al contenido</a>
  <PageLoader />
  <SiteBackground />
  <slot />

  <script>
    import '../scripts/interactive-dots.ts';
  </script>
  <script>
    const io = new IntersectionObserver(
      es => es.forEach(e => {
        if (e.isIntersecting) { e.target.classList.add('visible'); io.unobserve(e.target); }
      }),
      { threshold: 0.08, rootMargin: '0px 0px -40px 0px' }
    );
    document.querySelectorAll('.reveal').forEach(el => io.observe(el));
  </script>

  <div id="recaptcha-root" aria-hidden="true"></div>
</body>
</html>
