---
import { readFile } from 'node:fs/promises';
import path from 'node:path';
import Base from './Base.astro';
import Navbar from '../components/sections/Navbar.astro';
import HeroArticulo from '../components/sections/blog/HeroArticulo.astro';
import BlogArticleCover from '../components/sections/blog/BlogArticleCover.astro';
import ArticuloContent from '../components/sections/blog/ArticuloContent.astro';
import BlogArticleCta from '../components/sections/blog/BlogArticleCta.astro';
import BlogArticleTags from '../components/sections/blog/BlogArticleTags.astro';
import BlogArticleShare from '../components/sections/blog/BlogArticleShare.astro';
import ArticuloRelacionados from '../components/sections/blog/ArticuloRelacionados.astro';
import Footer from '../components/sections/Footer.astro';
import { blogOgPath } from '../data/blogImages';
import type { CollectionEntry } from 'astro:content';
import { getCollection, render } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { Content } = await render(post);

let related: CollectionEntry<'blog'>[] = [];
if (post.data.relatedSlugs?.length) {
  const allPosts = await getCollection('blog');
  related = post.data.relatedSlugs
    .map((id) => allPosts.find((p) => p.id === id))
    .filter((p): p is CollectionEntry<'blog'> => Boolean(p));
}

const rawMd = await readFile(path.join(process.cwd(), 'src/content/blog', `${post.id}.md`), 'utf8');
const markdownBody = rawMd.replace(/^---[\s\S]*?---\s*/, '').trim();
const wordCount = markdownBody ? markdownBody.split(/\s+/).filter(Boolean).length : 0;

const articleUrl = new URL(`/blog/${post.id}/`, Astro.site).href;
const ogImagePath = post.data.ogImage ?? blogOgPath(post.id);
const publisherLogoUrl = new URL('/android-chrome-512x512.png', Astro.site).href;

const blogPostingSchema = {
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.date.toISOString(),
  ...(post.data.updatedDate && { dateModified: post.data.updatedDate.toISOString() }),
  inLanguage: 'es-ES',
  wordCount,
  author: { '@type': 'Person', name: 'Flor Rímolo', url: 'https://rimobyte.com/' },
  publisher: {
    '@type': 'Organization',
    name: 'RimoByte',
    url: 'https://rimobyte.com/',
    logo: {
      '@type': 'ImageObject',
      url: publisherLogoUrl,
      width: 512,
      height: 512,
    },
  },
  mainEntityOfPage: articleUrl,
  image: new URL(ogImagePath, Astro.site).href,
  keywords: post.data.keywords.join(', '),
};

const breadcrumbBlogSchema = {
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Inicio',
      item: new URL('/', Astro.site).href,
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Blog',
      item: new URL('/blog/', Astro.site).href,
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: post.data.title,
      item: articleUrl,
    },
  ],
};

const articleLdGraph = {
  '@context': 'https://schema.org',
  '@graph': [blogPostingSchema, breadcrumbBlogSchema],
};

const publishedIso = post.data.date.toISOString();
const modifiedIso = (post.data.updatedDate ?? post.data.date).toISOString();
---

<Base
  title={`${post.data.title} · RimoByte`}
  description={post.data.description}
  image={ogImagePath}
  ogType="article"
  articlePublishedTime={publishedIso}
  articleModifiedTime={modifiedIso}
>
  <script
    slot="head"
    is:inline
    type="application/ld+json"
    set:html={JSON.stringify(articleLdGraph)}
  />

  <div class="blog-reading-progress" id="blogReadingProgress" aria-hidden="true"></div>

  <Navbar />
  <main id="main">
    <HeroArticulo post={post} />
    <BlogArticleCover slug={post.id} title={post.data.title} />
    <ArticuloContent>
      <Content />
    </ArticuloContent>

    <BlogArticleCta title={post.data.ctaText} href={post.data.ctaLink} />
    <BlogArticleTags keywords={post.data.keywords} />
    <BlogArticleShare url={articleUrl} title={post.data.title} />

    {related.length > 0 && <ArticuloRelacionados posts={related} />}
  </main>
  <Footer />
</Base>

<script>
  function initReadingProgress() {
    const bar = document.getElementById('blogReadingProgress');
    if (!bar) return;

    const update = () => {
      const scrollTop = document.documentElement.scrollTop || document.body.scrollTop;
      const scrollHeight =
        (document.documentElement.scrollHeight || document.body.scrollHeight) -
        document.documentElement.clientHeight;
      const pct = scrollHeight > 0 ? (scrollTop / scrollHeight) * 100 : 0;
      bar.style.width = `${pct}%`;
    };

    update();
    window.addEventListener('scroll', update, { passive: true });
    window.addEventListener('resize', update);
  }

  initReadingProgress();
  document.addEventListener('astro:page-load', initReadingProgress);
</script>
