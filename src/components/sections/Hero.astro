---
import Button from '../ui/Button.astro';
import HeroStats from '../ui/HeroStats.astro';
import SiteWrap from '../ui/SiteWrap.astro';
import { projectCount } from '../../data/projects';
import { fetchPlaceAggregate } from '../../lib/google-reviews';

const placeAgg = await fetchPlaceAggregate();
const reviewCount = placeAgg?.reviewCount ?? 10;

const heroStats = [
  { value: String(projectCount), label: 'Negocios online' },
  { value: '5★', label: `${reviewCount} reseñas Google` },
  { value: '7', label: 'Años de experiencia' },
  { value: '100%', label: 'Propiedad del cliente' },
];
---

<header class="hero-v6">
  <SiteWrap>
    <h1 class="reveal">
      Webs <span class="gradient-text">que venden,</span> no que decoran.
    </h1>
    <p class="hero-v6__lede reveal">
      Soy Flor, ingeniera informática. Diseño y desarrollo webs WordPress a medida para negocios locales que
      quieren existir profesionalmente online — sin plantillas, sin intermediarios, sin letra pequeña.
    </p>
    <div class="hero-v6__cta reveal">
      <Button href="#contacto" variant="primary">Cuéntame tu proyecto</Button>
      <Button href="#proyectos" variant="outline">Ver portfolio</Button>
    </div>

    <HeroStats stats={heroStats} />
  </SiteWrap>
</header>
