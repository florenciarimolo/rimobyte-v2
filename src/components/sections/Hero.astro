---
import Eyebrow from '../ui/Eyebrow.astro';
import Button from '../ui/Button.astro';
---
<section class="hero-screen__hero relative">

  <div class="hero-screen__hero-inner relative max-w-[1200px] mx-auto px-[clamp(1.5rem,5vw,4rem)]">
    <div class="mx-auto flex max-w-[760px] flex-col items-center text-center">

      <div class="reveal flex justify-center">
        <Eyebrow text="DISEÑO WEB · DESARROLLO · ESPAÑA" />
      </div>

      <h1 class="hero-screen__title reveal text-[clamp(2.75rem,5.5vw,4.5rem)] leading-[1.02] tracking-[-0.03em] mb-4 md:mb-5">
        Muchos negocios pagan por una web que <em>no controlan.</em>
      </h1>

      <p class="hero-screen__lead reveal text-[clamp(0.9375rem,1.8vw,1.0625rem)] leading-[1.65] text-(--color-text-secondary) mb-5 md:mb-6 max-w-[540px]">
        Soy Flor, ingeniera informática especializada en desarrollo web. Creo webs para negocios locales con acompañamiento real y sin letra pequeña — tuya desde el primer día.
      </p>

      <div class="hero-screen__ctas reveal flex flex-wrap justify-center gap-3">
        <Button href="#contacto" variant="primary">Quiero empezar mi web</Button>
        <Button href="#contacto" variant="outline">Tengo dudas, cuéntame más</Button>
      </div>

      <ul class="hero-screen__checks reveal flex flex-wrap justify-center gap-x-6 gap-y-2 list-none p-0 m-0">
        {['Tu web, tu propiedad', 'Sin sorpresas', 'Soporte continuo'].map(item => (
          <li class="flex items-center gap-2 font-(--font-body) text-sm text-(--color-text-secondary)">
            <span class="w-1.5 h-1.5 rounded-full bg-(--color-blue) opacity-60 shrink-0"></span>
            {item}
          </li>
        ))}
      </ul>

    </div>
  </div>
</section>
