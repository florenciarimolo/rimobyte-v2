---
import Button from '../ui/Button.astro';
import Eyebrow from '../ui/Eyebrow.astro';
import SiteWrap from '../ui/SiteWrap.astro';
import HeroShowcase from '../ui/HeroShowcase.astro';
---

<section class="landing-hero">
  <SiteWrap class="landing-hero__layout">
    <div class="hero__copy">
      <Eyebrow text="Diseño web · Desarrollo · España" class="reveal" />
      <h1 class="reveal">
        Muchos negocios pagan por una web que <em>no controlan.</em>
      </h1>
      <p class="landing-hero__sub reveal">
        Soy Flor, ingeniera informática. Creo webs para negocios locales con acompañamiento real y sin letra pequeña — tuya desde el primer día.
      </p>
      <div class="landing-hero__btns reveal">
        <Button href="#contacto" variant="primary">Quiero empezar mi web</Button>
        <Button href="#por-que" variant="outline">Cómo trabajo</Button>
      </div>
      <ul class="landing-hero__checks reveal">
        <li>Tu web, tu propiedad</li>
        <li>Sin sorpresas</li>
        <li>Soporte continuo</li>
      </ul>
    </div>

    <HeroShowcase moreHref="#proyectos" class="reveal" />
  </SiteWrap>
</section>
