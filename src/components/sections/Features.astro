---
import Eyebrow from '../ui/Eyebrow.astro';
import FeatureCard from '../ui/FeatureCard.astro';

const features = [
  {
    num: '01', span: 'tall',
    title: 'Hablas conmigo, siempre',
    body: 'No hay intermediarios ni equipos que rotan. Desde el primer mensaje hasta la entrega, soy yo quien diseña, desarrolla y responde. Tú sabes con quién hablas en cada momento.',
    footnote: 'Flor · de principio a fin',
  },
  {
    num: '02', span: '',
    title: 'Tu web es tuya, sin condiciones',
    body: 'El dominio, el hosting y todos los accesos van a tu nombre desde el primer día.',
    footnote: 'Dominio · hosting · accesos',
  },
  {
    num: '03', span: '',
    title: 'Sigo aquí cuando la web ya está',
    body: 'Mantenimiento y soporte continuo sin permanencia.',
    footnote: 'Soporte · sin permanencia',
  },
  {
    num: '04', span: 'wide',
    title: 'Ingeniera, no diseñadora reconvertida',
    body: 'Graduada en 2019. Cuando hay un problema técnico complejo, lo resuelvo. Tu web está construida con criterio de ingeniería, no solo de estética.',
    footnote: 'Ingeniería · no solo diseño',
  },
];
---
<section class="section-bg py-[clamp(4rem,8vw,7rem)]">
  <div class="max-w-[1200px] mx-auto px-[clamp(1.5rem,5vw,4rem)]">

    <Eyebrow text="POR QUÉ RIMOBYTE" />
    <h2 class="text-[clamp(2rem,3.5vw,3rem)] leading-[1.08] tracking-[-0.025em] mb-4 max-w-[500px]">
      Una forma <em>diferente</em> de hacer las cosas.
    </h2>
    <p class="text-base leading-[1.75] text-text-secondary mb-12 max-w-[560px]">
      Cuatro razones que cambian cómo trabajamos juntos — y cómo te quedas tú al final del proyecto.
    </p>

    <!-- Grid asimétrico — desktop -->
    <div class="hidden md:grid gap-3" style="grid-template-columns: 5fr 3.5fr 3.5fr; grid-template-rows: auto auto;">
      {features.map((f) => (
        <FeatureCard
          num={f.num}
          title={f.title}
          body={f.body}
          footnote={f.footnote}
          tall={f.span === 'tall'}
          wide={f.span === 'wide'}
          style={`
            ${f.span === 'tall' ? 'grid-row: span 2;' : ''}
            ${f.span === 'wide' ? 'grid-column: span 2;' : ''}
          `}
        />
      ))}
    </div>

    <!-- Grid simple — móvil -->
    <div class="grid md:hidden gap-3">
      {features.map((f) => (
        <FeatureCard
          num={f.num}
          title={f.title}
          body={f.body}
          footnote={f.footnote}
        />
      ))}
    </div>

  </div>
</section>
