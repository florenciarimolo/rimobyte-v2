---
import SectionShell from '../ui/SectionShell.astro';
import SiteWrap from '../ui/SiteWrap.astro';
import SectionHead from '../ui/SectionHead.astro';

const principles = [
  {
    num: '01 / Cercanía',
    title: 'Hablas siempre conmigo',
    body: 'Sin equipos que rotan ni cuentas intermedias. Diseño, programo y respondo yo, de principio a fin.',
  },
  {
    num: '02 / Propiedad',
    title: 'Tu web es tuya, de verdad',
    body: 'Dominio, hosting, accesos y código a tu nombre desde el día uno. Sin cerrojos invisibles.',
  },
  {
    num: '03 / Continuidad',
    title: 'Aquí cuando ya está online',
    body: 'Mantenimiento, actualizaciones y soporte sin permanencia. Te quedas porque quieres.',
  },
  {
    num: '04 / Criterio',
    title: 'Ingeniería, no apaños',
    body: 'Graduada en 2019. Cuando algo se complica — migraciones, APIs, plugins — lo resuelvo con criterio técnico.',
  },
];
---

<SectionShell id="filosofia" transparent padding="home">
  <SiteWrap>
    <SectionHead
      pill="Filosofía"
      title="Cuatro promesas que cambian"
      titleGradient="cómo trabajamos juntos."
      subtitle="Trabajo como me gustaría que trabajaran conmigo: con tiempo, con criterio y sin sorpresas. Estas son las cuatro reglas que firmo en cada proyecto."
      class="reveal"
    />

    <div class="principles">
      {
        principles.map((p) => (
          <article class="principle glass-card glass-card--hover reveal">
            <div class="principle__num">{p.num}</div>
            <h3>{p.title}</h3>
            <p>{p.body}</p>
          </article>
        ))
      }
    </div>
  </SiteWrap>
</SectionShell>
