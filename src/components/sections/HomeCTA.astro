---
import Button from '../ui/Button.astro';
import DarkCTA from '../ui/DarkCTA.astro';
---

<DarkCTA pill="Respondo en menos de 24 horas" live>
  <span slot="title">
    ¿Le ponemos cara a <span class="gradient-text">tu web?</span>
  </span>
  <span slot="description">
    Sin compromiso y sin tecnicismos. Te respondo personalmente con ideas concretas — no una plantilla de
    presupuesto.
  </span>
  <Fragment slot="actions">
    <Button href="/contacto/" variant="primary">
      Contacta conmigo
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
        <path d="M5 12h14M13 5l7 7-7 7" />
      </svg>
    </Button>
    <Button href="https://wa.me/34684713743" variant="ghost" external>
      WhatsApp · 684 713 743
    </Button>
  </Fragment>
</DarkCTA>
