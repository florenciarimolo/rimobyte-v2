---
import Eyebrow from '../ui/Eyebrow.astro';
import ServiceCard from '../ui/ServiceCard.astro';
import type { IconName } from '../ui/icons/registry';

const services: {
  icon: IconName;
  title: string;
  desc: string;
  price: string;
  href: string;
}[] = [
  {
    icon: 'globe',
    title: 'Web corporativa',
    desc: 'Para negocios que quieren existir profesionalmente en internet. Tus clientes te encuentran y te contactan.',
    price: 'Desde 600€',
    href: '/servicios/web-corporativa',
  },
  {
    icon: 'shopping-bag',
    title: 'Tienda online',
    desc: 'Para negocios que quieren vender las 24 horas. Acepta pagos, gestiona pedidos, escala.',
    price: 'Desde 1.200€',
    href: '/servicios/tienda-online',
  },
  {
    icon: 'wrench',
    title: 'Mantenimiento',
    desc: 'Para quienes no quieren preocuparse por lo técnico. Sin permanencia, sin letra pequeña.',
    price: 'Desde 50€/mes',
    href: '/servicios/mantenimiento-web',
  },
];
---
<section class="section-bg py-[clamp(4rem,8vw,7rem)]">
  <div class="max-w-layout mx-auto px-[clamp(1.5rem,5vw,4rem)]">

    <Eyebrow text="SERVICIOS" />
    <h2 class="text-[clamp(2rem,3.5vw,3rem)] leading-[1.08] tracking-[-0.025em] mb-12">
      Lo que hago, y lo que <em>te consigue.</em>
    </h2>

    <div class="grid md:grid-cols-3 gap-3">
      {services.map((s) => (
        <ServiceCard
          icon={s.icon}
          title={s.title}
          body={s.desc}
          price={s.price}
          href={s.href}
        />
      ))}
    </div>

  </div>
</section>
