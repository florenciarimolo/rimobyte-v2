---
import SectionShell from '../ui/SectionShell.astro';
import SiteWrap from '../ui/SiteWrap.astro';
import SectionHead from '../ui/SectionHead.astro';
import ServiceCard from '../ui/ServiceCard.astro';
import { services } from '../../data/services';
import type { IconName } from '../ui/icons/registry';

const iconByIllustration: Record<string, IconName> = {
  corporate: 'globe',
  ecommerce: 'shopping-bag',
  maintenance: 'wrench',
};
---

<SectionShell id="servicios" transparent padding="home">
  <SiteWrap>
    <SectionHead
      pill="Servicios"
      title="Tres formas de empezar a trabajar"
      titleGradient="juntas."
      subtitle="Cada proyecto es único, pero estos son los puntos de partida más habituales. Si tu caso no encaja del todo, escríbeme — lo adaptamos."
      class="reveal"
    />

    <div class="services-glass">
      {
        services.map((s) => (
          <ServiceCard
            icon={iconByIllustration[s.illustration] ?? 'globe'}
            title={s.name}
            body={s.description.split('.')[0] + '.'}
            price={s.price}
            priceNote={s.priceNote}
            href={`/servicios/${s.slug}/`}
            features={s.features}
          />
        ))
      }
    </div>
  </SiteWrap>
</SectionShell>
