---
import SectionShell from '../ui/SectionShell.astro';
import SiteWrap from '../ui/SiteWrap.astro';
import SectionHead from '../ui/SectionHead.astro';
import ServiceCard from '../ui/ServiceCard.astro';
import { services } from '../../data/services';
import type { IconName } from '../ui/icons/registry';

const iconByIllustration: Record<string, IconName> = {
  corporate: 'globe',
  ecommerce: 'shopping-bag',
  maintenance: 'wrench',
};
---

<SectionShell id="servicios">
  <SiteWrap>
    <SectionHead
      title="Servicios"
      subtitle="Lo que hago, y lo que te consigue."
      class="reveal"
    />

    <div class="landing-services">
      {services.map((s) => (
        <ServiceCard
          icon={iconByIllustration[s.illustration] ?? 'globe'}
          title={s.name}
          body={s.description.split('.')[0] + '.'}
          price={s.price}
          href={`/servicios/${s.slug}/`}
        />
      ))}
    </div>
  </SiteWrap>
</SectionShell>
