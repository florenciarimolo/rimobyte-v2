---
import SiteWrap from '../ui/SiteWrap.astro';
import { projectCount } from '../../data/projects';
---

<section class="landing-metrics">
  <SiteWrap class="landing-metrics__row">
    <div class="landing-metrics__cell reveal">
      <strong data-count={projectCount}>0</strong>
      <span>Proyectos entregados</span>
    </div>
    <div class="landing-metrics__cell reveal">
      <strong data-count="5">0</strong>
      <span>Sectores distintos</span>
    </div>
    <div class="landing-metrics__cell reveal">
      <strong>5/5 ★</strong>
      <span>10 reseñas en Google</span>
    </div>
    <div class="landing-metrics__cell reveal">
      <strong data-count="100" data-suffix="%">0</strong>
      <span>Clientes con acceso total</span>
    </div>
  </SiteWrap>
</section>
