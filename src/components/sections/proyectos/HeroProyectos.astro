---
import Pill from '../../ui/Pill.astro';
import SiteWrap from '../../ui/SiteWrap.astro';
import { projectCount } from '../../../data/projects';
---

<header class="projects-hero-v6">
  <SiteWrap>
    <div class="reveal">
      <Pill text="Portfolio · Casos documentados" class="mb-6" />
      <h1>
        Proyectos reales para negocios <span class="gradient-text">reales.</span>
      </h1>
      <p class="projects-hero-v6__lede">
        Cada web tiene detrás una historia: un negocio que quería crecer, un autónomo que quería ser
        encontrado o una tienda que quería vender online. Estos son los {projectCount}.
      </p>
    </div>
  </SiteWrap>
</header>
