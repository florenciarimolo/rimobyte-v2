---
import SectionShell from '../../ui/SectionShell.astro';
import SiteWrap from '../../ui/SiteWrap.astro';
import SectionHead from '../../ui/SectionHead.astro';
import Eyebrow from '../../ui/Eyebrow.astro';
import ServiceCaseCard from '../../ui/ServiceCaseCard.astro';
import type { RelatedCase } from '../../../data/services';
import { getRelatedProject } from '../../../data/services';

interface Props {
  cases: RelatedCase[];
  title?: string;
  titleEm?: string;
}

const {
  cases,
  title = 'Proyectos que hablan',
  titleEm = 'por sí solos.',
} = Astro.props;
---

<SectionShell>
  <SiteWrap>
    <Eyebrow text="CASOS REALES" class="reveal mb-6" />
    <SectionHead title={title} titleEm={titleEm} class="reveal" narrow={false} />

    <div class="service-case-list">
      {
        cases.map((caseItem) => {
          const project = getRelatedProject(caseItem.slug);
          if (!project) return null;
          return (
            <ServiceCaseCard
              quote={caseItem.testimonialQuote}
              highlight={caseItem.highlight}
              project={project}
            />
          );
        })
      }
    </div>
  </SiteWrap>
</SectionShell>
