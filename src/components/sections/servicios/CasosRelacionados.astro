---
import Eyebrow from '../../ui/Eyebrow.astro';
import QuoteIcon from '../../ui/QuoteIcon.astro';
import type { RelatedCase } from '../../../data/services';
import { getRelatedProject } from '../../../data/services';

interface Props {
  cases: RelatedCase[];
}

const { cases } = Astro.props;
---

<section class="section-bg py-[clamp(5rem,9vw,7rem)]">
  <div class="mx-auto max-w-[var(--max-width-layout)] px-[clamp(1.5rem,5vw,4rem)]">
    <div class="reveal mb-10">
      <Eyebrow text="CASOS REALES" class="mb-6" />
      <h2
        class="headline-gradient font-display font-medium text-[clamp(2rem,3.5vw,3rem)] leading-[1.05] tracking-[-0.025em]"
      >
        Proyectos que hablan <em>por sí solos.</em>
      </h2>
    </div>

    <div class="grid grid-cols-1 gap-4 md:grid-cols-3">
      {
        cases.map((caseItem) => {
          const project = getRelatedProject(caseItem.slug);
          if (!project) return null;
          return (
            <a
              href={`/proyectos/${project.slug}`}
              class="reveal case-card group flex flex-col overflow-hidden rounded-[14px] border border-border-default bg-[rgba(22,22,42,0.38)] text-inherit no-underline transition-[border-color,background] duration-200 hover:border-border-blue hover:bg-[rgba(30,30,53,0.52)]"
            >
              <div class="aspect-[16/10] overflow-hidden border-b border-border-default">
                <img
                  src={project.image}
                  alt={`Captura de ${project.name}`}
                  loading="lazy"
                  decoding="async"
                  class="block size-full object-cover object-top transition-transform duration-[600ms] ease-[--ease-spring] group-hover:scale-[1.03]"
                />
              </div>

              <div class="flex flex-1 flex-col gap-3 px-5 pt-5 pb-5">
                <div>
                  <h3 class="mb-2 font-display text-[1.125rem] font-medium leading-[1.3] text-text-primary">
                    {project.name}
                  </h3>
                  <p class="m-0 font-body text-[0.8125rem] leading-[1.7] text-text-secondary">{caseItem.highlight}</p>
                </div>

                <div class="mt-auto border-t border-border-default pt-4">
                  <QuoteIcon variant="ornate" size="xs" tone="strong" class="mb-2 block leading-none" />
                  <p class="m-0 font-body text-[0.875rem] italic leading-[1.55] text-white">
                    {caseItem.testimonialQuote}
                  </p>
                </div>
              </div>
            </a>
          );
        })
      }
    </div>
  </div>
</section>
