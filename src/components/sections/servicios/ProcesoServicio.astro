---
import SiteWrap from '../../ui/SiteWrap.astro';
import Pill from '../../ui/Pill.astro';
import type { ServiceProcessStep } from '../../../data/servicesHub';

interface Props {
  pill?: string;
  title: string;
  titleEm: string;
  description: string;
  steps: ServiceProcessStep[];
  centered?: boolean;
}

const { pill = 'Cómo trabajamos', title, titleEm, description, steps, centered = false } = Astro.props;
---

<section class:list={['service-v6-process', centered && 'service-v6-process--centered']}>
  <SiteWrap>
    <div class:list={['service-v6-process__head', 'reveal', centered && 'service-v6-process__head--centered']}>
      <Pill text={pill} class="mb-5" />
      <h2>
        {title}
        <span class="gradient-text">{titleEm}</span>
      </h2>
      <p>{description}</p>
    </div>
    <div class="service-v6-process__steps">
      {
        steps.map((step, i) => (
          <div class="service-v6-process__step reveal">
            <div class="service-v6-process__num">{String(i + 1).padStart(2, '0')}</div>
            <h3>{step.title}</h3>
            <p>{step.description}</p>
          </div>
        ))
      }
    </div>
  </SiteWrap>
</section>
