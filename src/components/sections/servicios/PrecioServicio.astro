---
import Eyebrow from '../../ui/Eyebrow.astro';

interface Props {
  price: string;
  note: string;
}

const { price, note } = Astro.props;

const cleaned = price.replace(/^Desde\s*/i, '').trim();
---

<section class="section-bg relative py-[clamp(5rem,10vw,8rem)]">
  <div class="mx-auto max-w-[var(--max-width-layout)] px-[clamp(1.5rem,5vw,4rem)]">
    <div
      class="reveal mb-[clamp(3rem,5vw,4.5rem)] flex items-baseline justify-between border-t border-border-default pt-6"
    >
      <span class="font-mono text-[0.625rem] uppercase tracking-[0.18em] text-text-muted">
        / 04 · Inversión
      </span>
      <span class="font-mono text-[0.625rem] uppercase tracking-[0.18em] text-text-muted">
        Presupuesto cerrado
      </span>
    </div>

    <div class="grid gap-x-[clamp(2rem,5vw,5rem)] gap-y-12 lg:grid-cols-[minmax(0,1.15fr)_minmax(0,1fr)] lg:items-end">
      <div class="reveal">
        <Eyebrow text="DESDE" class="mb-3" />
        <p
          class="price-display m-0 font-display text-[clamp(3.25rem,9vw,6.5rem)] font-medium leading-[0.9] tracking-[-0.04em] text-blue"
        >
          {cleaned}
        </p>
        <p class="mt-8 max-w-[36ch] font-body text-base leading-[1.7] text-text-secondary">
          Te paso el presupuesto cerrado antes de empezar. Lo que ves aquí es lo que pagas — sin extras que aparecen al final.
        </p>
      </div>

      <div class="reveal price-side relative">
        <Eyebrow text="LO QUE NO ESTÁ INCLUIDO" class="mb-5" />
        <p class="m-0 max-w-[42ch] font-body text-[1rem] leading-[1.7] text-text-secondary">
          {note}
        </p>

        <dl
          class="mt-10 grid grid-cols-[auto_1fr] items-center gap-x-6 gap-y-3 border-t border-border-default pt-6"
        >
          <dt class="font-mono text-[0.625rem] uppercase tracking-[0.16em] text-text-muted">
            Entrega
          </dt>
          <dd class="m-0 font-body text-[0.9375rem] text-text-secondary">3–4 semanas</dd>

          <dt class="font-mono text-[0.625rem] uppercase tracking-[0.16em] text-text-muted">
            Iteraciones
          </dt>
          <dd class="m-0 font-body text-[0.9375rem] text-text-secondary">2 propuestas de diseño</dd>

          <dt class="font-mono text-[0.625rem] uppercase tracking-[0.16em] text-text-muted">
            Accesos
          </dt>
          <dd class="m-0 font-body text-[0.9375rem] text-text-secondary">Todos a tu nombre</dd>
        </dl>
      </div>
    </div>
  </div>
</section>

<style>
  .price-side::before {
    content: '';
    position: absolute;
    top: 0.25rem;
    left: 0;
    width: 1px;
    height: 100%;
    background: linear-gradient(180deg, var(--color-blue) 0%, rgba(43, 71, 236, 0) 100%);
    opacity: 0.5;
  }

  @media (max-width: 1023px) {
    .price-side {
      padding-left: 1.5rem;
    }
  }

  @media (min-width: 1024px) {
    .price-side {
      padding-left: clamp(1.5rem, 3vw, 3rem);
    }
  }
</style>
