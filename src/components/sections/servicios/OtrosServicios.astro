---
import SectionShell from '../../ui/SectionShell.astro';
import SiteWrap from '../../ui/SiteWrap.astro';
import SectionHead from '../../ui/SectionHead.astro';
import Eyebrow from '../../ui/Eyebrow.astro';
import ServiceCard from '../../ui/ServiceCard.astro';
import type { IconName } from '../../ui/icons/registry';
import { getOtherServices } from '../../../data/services';

interface Props {
  currentSlug: string;
}

const { currentSlug } = Astro.props;
const others = getOtherServices(currentSlug);

const ICON_BY_SLUG: Partial<Record<string, IconName>> = {
  'web-corporativa': 'globe',
  'tienda-online': 'shopping-bag',
  'mantenimiento-web': 'wrench',
};

function iconForSlug(slug: string): IconName {
  return ICON_BY_SLUG[slug] ?? 'globe';
}
---

{
  others.length > 0 && (
    <SectionShell elevated padding="none" class="py-[clamp(4rem,7vw,5rem)]">
      <SiteWrap>
        <Eyebrow text="OTROS SERVICIOS" class="reveal mb-6" />
        <SectionHead title="También puedo ayudarte con" titleEm="esto." class="reveal" narrow={false} />

        <div class="landing-services">
          {others.map((s) => (
            <ServiceCard
              icon={iconForSlug(s.slug)}
              title={s.name}
              body={s.description.split('.')[0] + '.'}
              price={s.price}
              href={`/servicios/${s.slug}/`}
            />
          ))}
        </div>
      </SiteWrap>
    </SectionShell>
  )
}
