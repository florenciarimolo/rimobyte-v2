---
import Eyebrow from '../../ui/Eyebrow.astro';
import ServiceCard from '../../ui/ServiceCard.astro';
import type { IconName } from '../../ui/icons/registry';
import { getOtherServices } from '../../../data/services';

interface Props {
  currentSlug: string;
}

const { currentSlug } = Astro.props;
const others = getOtherServices(currentSlug);

/** Íconos alineados con `Services.astro` en la home */
const ICON_BY_SLUG: Partial<Record<string, IconName>> = {
  'web-corporativa': 'globe',
  'tienda-online': 'shopping-bag',
  'mantenimiento-web': 'wrench',
};

function iconForSlug(slug: string): IconName {
  return ICON_BY_SLUG[slug] ?? 'globe';
}
---

{
  others.length > 0 && (
    <section class="section-bg--elevated py-[clamp(4rem,7vw,5rem)]">
      <div class="mx-auto max-w-layout px-[clamp(1.5rem,5vw,4rem)]">
        <div class="reveal mb-8">
          <Eyebrow text="OTROS SERVICIOS" class="mb-4" />
        </div>

        <div class="grid grid-cols-1 gap-3 md:grid-cols-2 lg:grid-cols-3">
          {others.map((s) => (
            <ServiceCard
              icon={iconForSlug(s.slug)}
              title={s.name}
              body={s.description}
              price={s.price}
              href={`/servicios/${s.slug}/`}
            />
          ))}
        </div>
      </div>
    </section>
  )
}
