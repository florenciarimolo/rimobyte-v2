---
import SectionShell from '../../ui/SectionShell.astro';
import SiteWrap from '../../ui/SiteWrap.astro';
import SectionHead from '../../ui/SectionHead.astro';
import Eyebrow from '../../ui/Eyebrow.astro';
import type { ServiceFeature } from '../../../data/services';

interface Props {
  features: ServiceFeature[];
}

const { features } = Astro.props;
---

<SectionShell elevated class="relative">
  <SiteWrap>
    <Eyebrow text="QUÉ INCLUYE" class="reveal mb-6" />
    <SectionHead
      title="Todo lo que necesitas,"
      titleEm="sin sorpresas."
      subtitle="Una lista sin trampa: cada punto es algo que se entrega y que puedes auditar en la web final."
      class="reveal"
      narrow={false}
    />

    <ol class="landing-manifest">
      {
        features.map((feature, i) => (
          <li class="landing-manifest__item reveal">
            <span class="landing-manifest__n">{String(i + 1).padStart(2, '0')}</span>
            <div>
              <h3>{feature.title}</h3>
              <p>{feature.description}</p>
            </div>
          </li>
        ))
      }
    </ol>
  </SiteWrap>
</SectionShell>
