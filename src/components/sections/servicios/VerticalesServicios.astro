---
import SiteWrap from '../../ui/SiteWrap.astro';
import Pill from '../../ui/Pill.astro';
import { hubVerticals } from '../../../data/servicesHub';

const iconPaths: Record<string, string> = {
  scissors: '<circle cx="6" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><line x1="20" y1="4" x2="8.12" y2="15.88"/><line x1="14.47" y1="14.48" x2="20" y2="20"/><line x1="8.12" y1="8.12" x2="12" y2="12"/>',
  utensils: '<path d="M3 2v7c0 1.1.9 2 2 2h0a2 2 0 0 0 2-2V2"/><path d="M7 2v20"/><path d="M21 15V2v0a5 5 0 0 0-5 5v6c0 1.1.9 2 2 2h3Zm0 0v7"/>',
  briefcase: '<rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/>',
  heart: '<path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>',
  dumbbell: '<path d="M6.5 6.5h11"/><path d="M6.5 17.5h11"/><path d="M6.5 6.5v11"/><path d="M17.5 6.5v11"/><path d="M3 8v8"/><path d="M21 8v8"/>',
  book: '<path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>',
  package: '<line x1="16.5" y1="9.4" x2="7.5" y2="4.21"/><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/>',
  chat: '<path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8z"/>',
};
---

<section class="services-hub-v6__verticals">
  <SiteWrap>
    <div class="services-hub-v6__verticals-head reveal">
      <Pill text="Especialidades" class="mb-5" />
      <h2>
        Webs pensadas para <span class="gradient-text">tu sector.</span>
      </h2>
      <p>
        Cada sector tiene su lenguaje, sus búsquedas en Google y sus puntos de conversión. Estas son las verticales
        donde tengo más experiencia y proceso afinado.
      </p>
    </div>
    <div class="services-hub-v6__verticals-grid">
      {
        hubVerticals.map((vertical) => (
          <a href={vertical.href} class="services-hub-v6__vertical glass-card reveal">
            <span class="services-hub-v6__vertical-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <Fragment set:html={iconPaths[vertical.icon]} />
              </svg>
            </span>
            <h3>{vertical.title}</h3>
            <p>{vertical.description}</p>
            <span class="services-hub-v6__vertical-link">
              {vertical.icon === 'chat' ? 'Hablamos →' : 'Ver más →'}
            </span>
          </a>
        ))
      }
    </div>
  </SiteWrap>
</section>
