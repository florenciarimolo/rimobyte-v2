---
import SectionShell from '../../ui/SectionShell.astro';
import SiteWrap from '../../ui/SiteWrap.astro';
import SectionHead from '../../ui/SectionHead.astro';
import Eyebrow from '../../ui/Eyebrow.astro';
import EditorialStack from '../../ui/EditorialStack.astro';

interface Props {
  points: string[];
  eyebrowText?: string;
  title?: string;
  titleEm?: string;
  footnote?: string;
}

const {
  points,
  eyebrowText = '¿PARA QUIÉN ES?',
  title = 'Si te suena alguna de',
  titleEm = 'estas situaciones.',
  footnote,
} = Astro.props;
---

<SectionShell class="relative">
  <SiteWrap>
    <Eyebrow text={eyebrowText} class="reveal mb-6" />
    <SectionHead
      title={title}
      titleEm={titleEm}
      subtitle="No hace falta encajar en todas. Con una basta para saber si este servicio es para ti."
      class="reveal"
      narrow={false}
    />

    <EditorialStack items={points} />

    {
      footnote && (
        <p class="reveal mt-8 max-w-[640px] font-body text-[clamp(0.9375rem,1.15vw,1rem)] leading-[1.65] text-text-secondary">
          {footnote}
        </p>
      )
    }
  </SiteWrap>
</SectionShell>
