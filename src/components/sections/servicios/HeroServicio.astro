---
import SectionShell from '../../ui/SectionShell.astro';
import SiteWrap from '../../ui/SiteWrap.astro';
import Eyebrow from '../../ui/Eyebrow.astro';
import Button from '../../ui/Button.astro';
import HeroShowcase from '../../ui/HeroShowcase.astro';
import type { Service } from '../../../data/services';

interface Props {
  service: Service;
}

const { service } = Astro.props;
---

<SectionShell padding="hero" class="overflow-hidden">
  <SiteWrap class="grid gap-12 min-[900px]:grid-cols-[1.15fr_0.85fr] min-[900px]:items-center min-[900px]:gap-16">
    <div class="relative z-10 max-w-[640px]">
      <Eyebrow text={service.eyebrow} class="mb-6" />

      <h1
        class="reveal mb-6 font-display text-[clamp(2.75rem,5.5vw,4.5rem)] font-medium leading-[1.02] tracking-[-0.03em] text-text-primary"
      >
        {service.headline}{' '}
        <em class="font-normal italic text-gradient-logo">{service.headlineEm}</em>
      </h1>

      <p
        class="reveal mb-8 max-w-[520px] font-body text-[clamp(1rem,1.4vw,1.125rem)] leading-[1.7] text-text-secondary"
      >
        {service.description}
      </p>

      <div class="reveal mb-10 flex flex-wrap gap-3">
        <Button href="#contacto" variant="primary">
          {service.ctaPrimary}
        </Button>
        <Button href="/proyectos/" variant="outline">
          {service.ctaSecondary} →
        </Button>
      </div>

      <ul class="reveal m-0 flex list-none flex-wrap gap-x-6 gap-y-2 p-0">
        {
          service.checks.map((check) => (
            <li class="flex items-center gap-2 font-body text-sm text-text-secondary">
              <span class="size-1.5 shrink-0 rounded-full bg-blue" aria-hidden="true" />
              {check}
            </li>
          ))
        }
      </ul>
    </div>

    <HeroShowcase class="reveal" />
  </SiteWrap>
</SectionShell>
