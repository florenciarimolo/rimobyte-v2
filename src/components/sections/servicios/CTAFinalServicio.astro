---
import Eyebrow from '../../ui/Eyebrow.astro';

interface Props {
  title: string;
  titleEm: string;
  text: string;
}

const { title, titleEm, text } = Astro.props;
---

<section id="contacto" class="section-bg--elevated relative py-[clamp(5rem,10vw,8rem)]">
  <div class="mx-auto max-w-[var(--max-width-layout)] px-[clamp(1.5rem,5vw,4rem)]">
    <div
      class="reveal mb-[clamp(3rem,5vw,4.5rem)] flex items-baseline justify-between border-t border-border-default pt-6"
    >
      <span class="font-mono text-[0.625rem] uppercase tracking-[0.18em] text-text-muted">
        / 05 · Siguiente paso
      </span>
      <span class="font-mono text-[0.625rem] uppercase tracking-[0.18em] text-text-muted">
        Respuesta &lt; 24 h
      </span>
    </div>

    <div class="reveal grid gap-y-10 lg:grid-cols-[minmax(0,1.4fr)_minmax(0,1fr)] lg:items-end lg:gap-x-[clamp(2rem,5vw,5rem)]">
      <div>
        <Eyebrow text="CUÉNTAME TU PROYECTO" class="mb-6" />
        <h2
          class="headline-gradient m-0 font-display text-[clamp(2.25rem,5vw,4rem)] font-medium leading-[1.02] tracking-[-0.03em]"
        >
          {title}{' '}<em class="cta-final__title-em">{titleEm}</em>
        </h2>
      </div>

      <p
        class="cta-final__text relative max-w-[44ch] pl-6 font-body text-[clamp(1rem,1.3vw,1.0625rem)] leading-[1.7] text-text-secondary lg:pl-8"
      >
        {text}
      </p>
    </div>
  </div>
</section>

<style>
  /* Evita halo blanco del degradado del título en la “j” inicial de <em> */
  .cta-final__title-em {
    padding-left: 0.18em;
    margin-left: 0.08em;
  }

  .cta-final__text::before {
    content: '';
    position: absolute;
    top: 0.5rem;
    bottom: 0.25rem;
    left: 0;
    width: 2px;
    background: var(--color-blue);
    opacity: 0.7;
  }
</style>
