---
import SectionShell from '../../ui/SectionShell.astro';
import SiteWrap from '../../ui/SiteWrap.astro';
import Eyebrow from '../../ui/Eyebrow.astro';

interface Props {
  title: string;
  titleEm: string;
  text: string;
}

const { title, titleEm, text } = Astro.props;
---

<SectionShell id="contacto" elevated class="relative">
  <SiteWrap>
    <div class="reveal grid gap-y-10 lg:grid-cols-[minmax(0,1.4fr)_minmax(0,1fr)] lg:items-center lg:gap-x-[clamp(2rem,5vw,5rem)]">
      <div>
        <Eyebrow text="CUÉNTAME TU PROYECTO" class="mb-6" />
        <h2
          class="m-0 font-display text-[clamp(2.25rem,5vw,4rem)] font-medium leading-[1.02] tracking-[-0.03em] text-text-primary"
        >
          {title}{' '}
          <em class="font-normal italic text-gradient-logo">{titleEm}</em>
        </h2>
      </div>

      <p
        class="cta-final__text relative max-w-[44ch] pl-6 font-body text-[clamp(1rem,1.3vw,1.0625rem)] leading-[1.7] text-text-secondary lg:pl-8"
      >
        {text}
      </p>
    </div>
  </SiteWrap>
</SectionShell>

<style>
  .cta-final__text::before {
    content: '';
    position: absolute;
    top: 0.5rem;
    bottom: 0.25rem;
    left: 0;
    width: 2px;
    background: var(--color-blue);
    opacity: 0.7;
  }
</style>
