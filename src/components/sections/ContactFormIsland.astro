---
import ContactForm from './ContactForm.tsx';
import { contactOriginFromPathname } from '../../lib/contact-origin';

interface Props {
  origin?: string;
  headingLevel?: 1 | 2;
  heading?: string;
  headingEm?: string;
  intro?: string;
  priceNote?: string;
  serviceLink?: string;
  omitAnchor?: boolean;
}

const {
  origin: originOverride,
  headingLevel = 2,
  heading,
  headingEm,
  intro,
  priceNote,
  serviceLink,
  omitAnchor,
} = Astro.props;

const origin = originOverride ?? contactOriginFromPathname(Astro.url.pathname);
const recaptchaSiteKey = import.meta.env.RECAPTCHA_SITE_KEY ?? '';
---

<ContactForm
  client:load
  recaptchaSiteKey={recaptchaSiteKey}
  origin={origin}
  headingLevel={headingLevel}
  heading={heading}
  headingEm={headingEm}
  intro={intro}
  priceNote={priceNote}
  serviceLink={serviceLink}
  omitAnchor={omitAnchor}
/>
