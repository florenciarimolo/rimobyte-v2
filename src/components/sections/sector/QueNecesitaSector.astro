---
import SectionShell from '../../ui/SectionShell.astro';
import SiteWrap from '../../ui/SiteWrap.astro';
import SectionHead from '../../ui/SectionHead.astro';
import Eyebrow from '../../ui/Eyebrow.astro';
import type { SectorFeature } from '../../../data/sectors';

interface Props {
  features: SectorFeature[];
  sectorName: string;
  intro?: string;
}

const { features, sectorName, intro } = Astro.props;
---

<SectionShell padding="none" class="relative py-[clamp(5rem,10vw,8rem)]">
  <SiteWrap>
    <Eyebrow text="QUÉ NECESITA TU WEB" class="reveal mb-6" />
    <SectionHead
      title={`Lo que convierte visitas en mesas en una web para ${sectorName}.`}
      class="reveal"
      narrow={false}
    />
    {intro && (
      <p class="reveal mb-8 max-w-[44ch] font-body text-[0.9375rem] leading-[1.7] text-text-secondary">
        {intro}
      </p>
    )}

    <ol class="landing-manifest">
      {
        features.map((feature, i) => (
          <li class="landing-manifest__item reveal">
            <span class="landing-manifest__n">{String(i + 1).padStart(2, '0')}</span>
            <div>
              <h3>{feature.title}</h3>
              <p>{feature.description}</p>
              {feature.tag && <span class="landing-manifest__tag">{feature.tag}</span>}
            </div>
          </li>
        ))
      }
    </ol>
  </SiteWrap>
</SectionShell>
