---
import Eyebrow from '../../ui/Eyebrow.astro';
import SectionHead from '../../ui/SectionHead.astro';
import SectionShell from '../../ui/SectionShell.astro';
import SiteWrap from '../../ui/SiteWrap.astro';

interface Props {
  eyebrow: string;
  title: string;
  titleEm: string;
  points: string[];
}

const { eyebrow, title, titleEm, points } = Astro.props;
---

<SectionShell elevated padding="none" class="relative py-[clamp(5rem,10vw,8rem)]">
  <SiteWrap>
    <Eyebrow text={eyebrow} class="reveal mb-6" />
    <SectionHead title={title} titleEm={titleEm} class="reveal" narrow={false} />
    <p class="reveal mb-8 max-w-[42ch] font-body text-[clamp(0.9375rem,1.15vw,1rem)] leading-[1.7] text-text-secondary">
      No hace falta tener todo resuelto. Con identificar el cuello de botella ya se puede diseñar la web correcta.
    </p>

    <ol class="landing-manifest">
      {
        points.map((point, i) => (
          <li class="landing-manifest__item reveal">
            <span class="landing-manifest__n">{String(i + 1).padStart(2, '0')}</span>
            <div>
              <h3>{point}</h3>
            </div>
          </li>
        ))
      }
    </ol>
  </SiteWrap>
</SectionShell>
