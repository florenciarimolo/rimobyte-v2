---
import SectionShell from '../../ui/SectionShell.astro';
import SiteWrap from '../../ui/SiteWrap.astro';
import Eyebrow from '../../ui/Eyebrow.astro';
import type { SectorCase } from '../../../data/sectors';
import { getSectorProject } from '../../../data/sectors';

interface Props {
  caseData: SectorCase;
}

const { caseData } = Astro.props;
const project = getSectorProject(caseData.slug);
if (!project) return;
---

<SectionShell>
  <SiteWrap>
    <Eyebrow text="CASO REAL" class="reveal mb-6" />

    <div class="landing-case__inner">
      <blockquote class="landing-case__line reveal">
        {caseData.testimonialQuote ? `«${caseData.testimonialQuote}»` : `«${caseData.summary}»`}
      </blockquote>
      <div class="landing-case__story reveal">
        <p>{caseData.summary}</p>
        <a href={`/proyectos/${project.slug}/`} class="landing-case__credit">
          {project.name} — {project.url} →
        </a>
      </div>
    </div>
  </SiteWrap>
</SectionShell>
