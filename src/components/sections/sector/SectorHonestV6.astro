---
import SiteWrap from '../../ui/SiteWrap.astro';
import Pill from '../../ui/Pill.astro';
import type { Sector } from '../../../data/sectors';

interface Props {
  painPoints: NonNullable<Sector['painPoints']>;
}

const { painPoints } = Astro.props;
---

<section class="sector-v6-honest">
  <SiteWrap>
    <div class="sector-v6-honest__card reveal">
      <div class="sector-v6-honest__grid">
        <div class="sector-v6-honest__main">
          <Pill text={painPoints.eyebrow} class="sector-v6-honest__pill" />
          <h2>
            {painPoints.title}
            <span class="gradient-text">{painPoints.titleEm}</span>
          </h2>
          {
            painPoints.paragraphs?.map((paragraph) => (
              <p>
                {paragraph.emphasis && <strong>{paragraph.emphasis}</strong>}
                {paragraph.text}
              </p>
            ))
          }
        </div>

        {
          painPoints.credentials && painPoints.credentials.length > 0 && (
            <aside class="sector-v6-honest__credentials">
              {painPoints.credentialsTitle && <h3>{painPoints.credentialsTitle}</h3>}
              <ul>
                {
                  painPoints.credentials.map((item) => (
                    <li>
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M20 6L9 17l-5-5" />
                      </svg>
                      <span>
                        <strong>{item.label}</strong> {item.text}
                      </span>
                    </li>
                  ))
                }
              </ul>
            </aside>
          )
        }
      </div>
    </div>
  </SiteWrap>
</section>
