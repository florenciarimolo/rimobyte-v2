---
import Icon from '../../ui/Icon.astro';

const linkedInUrl =
  import.meta.env.PUBLIC_LINKEDIN_URL?.trim() || 'https://www.linkedin.com/in/florencia-rimolofigueira';
const linkedInPath = (() => {
  try {
    return new URL(linkedInUrl).pathname.replace(/\/$/, '') || '/in/florencia-rimolofigueira';
  } catch {
    return '/in/florencia-rimolofigueira';
  }
})();
---

<aside class="contact-v6-aside">
  <div class="contact-v6-aside__card glass-card">
    <h2>Otras formas de contacto</h2>
    <div class="contact-v6-channels">
      <a href="mailto:info@rimobyte.com" class="contact-v6-channel">
        <span class="contact-v6-channel__icon" aria-hidden="true">
          <Icon name="mail" class="[&_svg]:size-[18px]" />
        </span>
        <span class="contact-v6-channel__info">
          <span class="contact-v6-channel__label">Email</span>
          <span class="contact-v6-channel__value">info@rimobyte.com</span>
        </span>
      </a>
      <a href="https://wa.me/34684713743" class="contact-v6-channel" target="_blank" rel="noopener noreferrer">
        <span class="contact-v6-channel__icon" aria-hidden="true">
          <Icon name="whatsapp" class="[&_svg]:size-[18px]" />
        </span>
        <span class="contact-v6-channel__info">
          <span class="contact-v6-channel__label">WhatsApp</span>
          <span class="contact-v6-channel__value">+34 684 713 743</span>
        </span>
      </a>
      <a href={linkedInUrl} class="contact-v6-channel" target="_blank" rel="noopener noreferrer">
        <span class="contact-v6-channel__icon" aria-hidden="true">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-4 0v7h-4v-7a6 6 0 0 1 6-6z" />
            <rect x="2" y="9" width="4" height="12" />
            <circle cx="4" cy="4" r="2" />
          </svg>
        </span>
        <span class="contact-v6-channel__info">
          <span class="contact-v6-channel__label">LinkedIn</span>
          <span class="contact-v6-channel__value">{linkedInPath}</span>
        </span>
      </a>
    </div>
  </div>

  <div class="contact-v6-aside__card glass-card">
    <h2>Datos rápidos</h2>
    <div class="contact-v6-meta">
      <div class="contact-v6-meta__item">
        <span class="contact-v6-meta__label">Base</span>
        <span class="contact-v6-meta__value">Barcelona, ES</span>
      </div>
      <div class="contact-v6-meta__item">
        <span class="contact-v6-meta__label">Respuesta</span>
        <span class="contact-v6-meta__value">&lt; 24 horas</span>
      </div>
      <div class="contact-v6-meta__item">
        <span class="contact-v6-meta__label">Idiomas</span>
        <span class="contact-v6-meta__value">ES · CAT · EN</span>
      </div>
      <div class="contact-v6-meta__item">
        <span class="contact-v6-meta__label">Activa</span>
        <span class="contact-v6-meta__value">Lun — Vie</span>
      </div>
    </div>
  </div>
</aside>
