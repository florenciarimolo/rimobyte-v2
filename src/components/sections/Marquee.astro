---
const items = [
  'Web corporativa',
  'Tienda online',
  'SEO local',
  'Mantenimiento real',
  'Negocios locales',
  'Diseño web',
  'Desarrollo web',
  'Tu web es tuya',
  'Sin sorpresas',
  'Soporte continuo',
  'Presupuesto claro',
  'Google local',
];
---

<div class="marquee-v6" aria-hidden="true">
  <div class="marquee-v6__track">
    {
      [...items, ...items].map((item) => (
        <span>{item}</span>
      ))
    }
  </div>
</div>
