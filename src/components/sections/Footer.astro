---
import LogoMark from '../ui/LogoMark.astro';
import SiteWrap from '../ui/SiteWrap.astro';
import { SERVICE_NAV_LINKS } from '../../data/navigation';

const year = new Date().getFullYear();
---

<footer class="footer-v6">
  <SiteWrap>
    <div class="footer-grid">
      <div class="footer-brand">
        <a href="/" class="footer-brand__logo">
          <LogoMark />
          RimoByte
        </a>
        <p>
          Diseño y desarrollo de webs WordPress a medida para negocios locales en España. Por Flor Rímolo, ingeniera
          informática freelance.
        </p>
      </div>

      <div class="footer-col">
        <h4>Servicios</h4>
        {
          SERVICE_NAV_LINKS.map(({ label, href }) => (
            <a href={href}>{label}</a>
          ))
        }
        <a href="/servicios/">Todos los servicios</a>
        <a href="/web-para-restaurantes/">Web para restaurantes</a>
        <a href="/web-para-peluquerias/">Web para peluquerías</a>
      </div>

      <div class="footer-col">
        <h4>RimoByte</h4>
        <a href="/proyectos/">Proyectos</a>
        <a href="/sobre-mi/">Sobre mí</a>
        <a href="/blog/">Blog</a>
        <a href="/contacto/">Contacto</a>
      </div>

      <div class="footer-col">
        <h4>Contacto</h4>
        <a href="mailto:info@rimobyte.com">info@rimobyte.com</a>
        <a href="https://wa.me/34684713743" target="_blank" rel="noopener noreferrer">+34 684 713 743</a>
        <span>Barcelona, España</span>
      </div>
    </div>

    <div class="footer-bottom">
      <span>© {year} RimoByte · Flor Rímolo</span>
      <span>
        <a href="/politica-privacidad/">Política de privacidad</a>
        {' · '}
        <a href="/politica-cookies/">Cookies</a>
      </span>
    </div>
  </SiteWrap>
</footer>
