---
const year = new Date().getFullYear();
---
<footer class="section-bg--elevated border-t border-(--color-border-default) py-10">
  <div class="max-w-[1200px] mx-auto px-[clamp(1.5rem,5vw,4rem)]">
    <div class="flex flex-col md:flex-row items-center justify-between gap-6">
      <a href="/" class="font-(--font-display) font-bold text-[1.25rem] tracking-[-0.03em] no-underline">
        <span class="text-white">Rimo</span><span class="text-gradient-logo">Byte</span>
      </a>
      <nav class="flex flex-wrap justify-center gap-6">
        {['Proyectos', 'Servicios', 'Sobre mí', 'Contacto'].map(item => (
          <a
            href={`/${item.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '').replace(/\s/g, '-')}`}
            class="text-sm text-(--color-text-secondary) no-underline hover:text-white transition-colors"
          >{item}</a>
        ))}
      </nav>
      <a href="mailto:info@rimobyte.com" class="text-sm text-(--color-text-secondary) no-underline hover:text-white transition-colors">
        info@rimobyte.com
      </a>
    </div>
    <div class="mt-8 pt-6 border-t border-(--color-border-default) text-center">
      <p class="font-(--font-mono) text-[0.6rem] tracking-[0.1em] uppercase text-(--color-text-muted)">
        © {year} RimoByte · Flor Rímolo
      </p>
    </div>
  </div>
</footer>
