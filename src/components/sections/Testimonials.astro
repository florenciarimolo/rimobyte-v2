---
import SiteWrap from '../ui/SiteWrap.astro';
import SectionHead from '../ui/SectionHead.astro';
import Stars from '../ui/Stars.astro';
import { featuredTestimonial, testimonialCards } from '../../data/homeTestimonials';
import { fetchGoogleReviews } from '../../lib/google-reviews';

const place = await fetchGoogleReviews(1);
const totalReviews = place?.totalReviews ?? 10;
const gbpUrl = import.meta.env.PUBLIC_GBP_URL?.trim();
const googleMapsUrl =
  place?.googleMapsUrl ??
  (gbpUrl || 'https://www.google.com/maps/search/?api=1&query=RimoByte');

function renderFeaturedQuote() {
  const { quote, quoteHighlight } = featuredTestimonial;
  if (!quoteHighlight) return quote;

  const idx = quote.indexOf(quoteHighlight);
  if (idx === -1) return quote;

  return {
    before: quote.slice(0, idx),
    highlight: quoteHighlight,
    after: quote.slice(idx + quoteHighlight.length),
  };
}

const featuredQuote = renderFeaturedQuote();
---

<section class="testimonials-v6" id="testimonios">
  <SiteWrap>
    <SectionHead
      pill="Lo que dicen"
      title="Lo que dicen quienes ya han trabajado"
      titleGradient="conmigo."
      class="reveal text-center mx-auto"
    />

    <article class="testimonial-feature glass-card reveal">
      <Stars />
      <blockquote>
        {
          typeof featuredQuote === 'string' ? (
            featuredQuote
          ) : (
            <>
              {featuredQuote.before}
              <span class="gradient-text">{featuredQuote.highlight}</span>
              {featuredQuote.after}
            </>
          )
        }
      </blockquote>
      <div class="testimonial-author">
        <span class="author-avatar" aria-hidden="true">{featuredTestimonial.initial}</span>
        <div class="author-info">
          <strong>{featuredTestimonial.author}</strong>
          <span>{featuredTestimonial.meta}</span>
        </div>
      </div>
    </article>

    <div class="testimonials-grid">
      {
        testimonialCards.map((item) => (
          <article class="testimonial-card glass-card reveal">
            <Stars />
            <p>{item.quote}</p>
            <div class="testimonial-author">
              <span class="author-avatar" aria-hidden="true">{item.initial}</span>
              <div class="author-info">
                <strong>{item.author}</strong>
                <span>{item.meta}</span>
              </div>
            </div>
          </article>
        ))
      }
    </div>

    <a
      href={googleMapsUrl}
      class="testimonials-v6__link reveal"
      target="_blank"
      rel="noopener noreferrer"
    >
      Ver las {totalReviews} reseñas →
    </a>
  </SiteWrap>
</section>
