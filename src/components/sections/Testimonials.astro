---
import Button from '../ui/Button.astro';
import Eyebrow from '../ui/Eyebrow.astro';
import QuoteIcon from '../ui/QuoteIcon.astro';
import { fetchGoogleReviews } from '../../lib/google-reviews';

const place = await fetchGoogleReviews(6);
const reviews = place?.reviews ?? [];
const totalReviews = place?.totalReviews ?? 10;
const googleMapsUrl = place?.googleMapsUrl ?? 'https://maps.google.com/?cid=166247164102179431';
---

<section class="section-bg--elevated py-[clamp(4rem,8vw,7rem)]">
  <div class="max-w-[1200px] mx-auto px-[clamp(1.5rem,5vw,4rem)]">

    <Eyebrow text="LO QUE DICEN" />
    <h2 class="text-[clamp(2rem,3.5vw,3rem)] leading-[1.08] tracking-[-0.025em] mb-12">
      Lo que dicen quienes ya han trabajado <em>conmigo.</em>
    </h2>

    {reviews.length > 0 ? (
      <div
        class="testimonials-carousel reveal"
        aria-roledescription="carousel"
        aria-label="Reseñas de clientes"
      >
        <div class="testimonials-carousel__track" aria-live="polite">
          {reviews.map((review, i) => (
            <article
              class:list={['testimonials-carousel__slide', i === 0 && 'is-active']}
              aria-hidden={i === 0 ? 'false' : 'true'}
              data-slide={i}
            >
              <QuoteIcon variant="ornate" size="xl" tone="strong" class="block mb-6 leading-none" />
              <blockquote class="testimonials-carousel__quote m-0">
                "{review.text}"
              </blockquote>
              <p class="testimonials-carousel__meta">
                {review.authorName}
                <span class="testimonials-carousel__meta-sep" aria-hidden="true">·</span>
                {review.relativeTime}
                <span class="testimonials-carousel__meta-sep" aria-hidden="true">·</span>
                Google
              </p>
            </article>
          ))}
        </div>

        {reviews.length > 1 && (
          <div
            class="testimonials-carousel__nav"
            role="tablist"
            aria-label="Elegir reseña"
          >
            {reviews.map((_, i) => (
              <button
                type="button"
                class:list={['testimonials-carousel__dot', i === 0 && 'is-active']}
                role="tab"
                aria-selected={i === 0 ? 'true' : 'false'}
                aria-label={`Reseña ${i + 1} de ${reviews.length}`}
                tabindex={i === 0 ? 0 : -1}
                data-index={i}
              />
            ))}
          </div>
        )}
      </div>
    ) : (
      <p class="text-(--color-text-secondary) text-sm">No se pudieron cargar las reseñas.</p>
    )}

    <div class="mt-10">
      <Button href={googleMapsUrl} variant="ghost" external>
        Ver las {totalReviews} reseñas en Google <span aria-hidden="true">→</span>
      </Button>
    </div>
  </div>
</section>

<script>
  import '../../scripts/testimonials-carousel.ts';
</script>
