---
import SectionShell from '../ui/SectionShell.astro';
import SiteWrap from '../ui/SiteWrap.astro';
import SectionHead from '../ui/SectionHead.astro';
import { faqEntries } from '../../data/faq';

interface FAQItem {
  q?: string;
  a?: string;
  aHtml?: string;
  question?: string;
  answer?: string;
  answerHtml?: string;
}

interface Props {
  faqs?: FAQItem[];
  id?: string;
  pill?: string;
  title?: string;
  titleGradient?: string;
  subtitle?: string;
  openFirst?: boolean;
}

const {
  faqs: faqsProp,
  id = 'faq',
  pill = 'Preguntas frecuentes',
  title = 'Dudas habituales antes de',
  titleGradient = 'empezar.',
  subtitle =
    'Estas son las preguntas que más recibo al primer correo. Si la tuya no está aquí, escríbeme — sin compromiso.',
  openFirst = false,
} = Astro.props;

function toFaqEntry(f: FAQItem) {
  return {
    q: f.q ?? f.question ?? '',
    a: f.a ?? f.answer ?? '',
    aHtml: f.aHtml ?? f.answerHtml,
  };
}

const entries = (faqsProp ?? faqEntries).map(toFaqEntry);
---

<SectionShell id={id} transparent padding="home" class="home-section--spacious">
  <SiteWrap>
    <SectionHead
      pill={pill}
      title={title}
      titleGradient={titleGradient}
      subtitle={subtitle}
      class="reveal"
    />
    <div class="faq-list reveal">
      {
        entries.map((f, index) => (
          <details class="faq-item" open={openFirst && index === 0 ? true : undefined}>
            <summary>{f.q}</summary>
            {f.aHtml ? <p set:html={f.aHtml} /> : <p>{f.a}</p>}
          </details>
        ))
      }
    </div>
  </SiteWrap>
</SectionShell>
