---
import Eyebrow from '../../ui/Eyebrow.astro';
import QuoteIcon from '../../ui/QuoteIcon.astro';

const testimonials = [
  {
    quote:
      'Gran profesional a nivel técnico y de equipo. Excelente optimización y desarrollo. Llegué a Rimobyte por recomendación, y sin duda paso su testigo a quien busque un técnico de confianza.',
    author: 'Maria Jose',
    company: 'DE COS',
    url: 'DECOS.ES',
  },
  {
    quote:
      'Atención al detalle y a las necesidades del cliente. Disponibilidad, buena comunicación, profesionalidad y rapidez en la entrega. Se ha convertido en la programadora oficial de nuestro proyecto.',
    author: 'Pilar',
    company: 'ROCK ZONE CAMP',
    url: 'ROCKZONECAMP.COM',
  },
];
---
<section class="section-bg--elevated py-[clamp(4rem,8vw,7rem)]">
  <div class="max-w-layout mx-auto px-[clamp(1.5rem,5vw,4rem)]">
    <div class="reveal">
      <Eyebrow text="LO QUE DICEN" />
      <h2 class="text-[clamp(2rem,3.5vw,3rem)] leading-[1.08] tracking-tight mb-12">
        Lo que dicen quienes ya han trabajado <em>conmigo.</em>
      </h2>
    </div>
    <div class="sobre-mi-testimonials__grid reveal">
      {testimonials.map((t, i) => (
        <article
          class:list={[
            'surface-card sobre-mi-testimonial-card',
            i === 0 && 'surface-card--lg',
          ]}
        >
          <QuoteIcon variant="ornate" size={i === 0 ? 'xl' : 'lg'} tone="subtle" class="mb-6" />
          <blockquote class="testimonials-carousel__quote flex-1 m-0">
            "{t.quote}"
          </blockquote>
          <p class="testimonials-carousel__meta">
            {t.author}
            <span class="testimonials-carousel__meta-sep" aria-hidden="true">·</span>
            {t.company}
            <span class="testimonials-carousel__meta-sep" aria-hidden="true">·</span>
            {t.url}
          </p>
        </article>
      ))}
    </div>
  </div>
</section>
