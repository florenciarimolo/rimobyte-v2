---
import SiteWrap from '../../ui/SiteWrap.astro';
import Pill from '../../ui/Pill.astro';
import Button from '../../ui/Button.astro';
import Icon from '../../ui/Icon.astro';
---

<header class="sobre-mi-hero">
  <SiteWrap class="sobre-mi-hero__grid">
    <div class="sobre-mi-hero__content">
      <Pill class="reveal">Ingeniera informática · Freelance</Pill>

      <h1 class="reveal">
        Construyo webs que funcionan de <em>verdad.</em>
      </h1>

      <p class="sobre-mi-hero__sub reveal">Y me aseguro de que sean siempre tuyas.</p>

      <p class="sobre-mi-hero__lede reveal">
        Soy Flor Rímolo. Trabajo directamente con negocios locales y autónomos que quieren una presencia
        online profesional, sin depender de nadie para mantenerla.
      </p>

      <div class="sobre-mi-hero__cta reveal">
        <Button href="/contacto/#formulario" variant="primary" class="inline-flex items-center gap-2">
          Hablemos de tu proyecto
          <Icon name="arrow-right" class="inline-flex size-3.5 [&_svg]:size-full" />
        </Button>
        <Button href="/proyectos/" variant="outline">Ver mis proyectos</Button>
      </div>
    </div>

    <div class="sobre-mi-portrait reveal">
      <div class="sobre-mi-portrait__inner">
        <img
          src="/assets/brand/flor-rimobyte.webp"
          alt="Flor Rímolo, ingeniera informática y diseñadora web freelance"
          width="440"
          height="550"
          loading="eager"
          decoding="async"
        />
      </div>
      <div class="sobre-mi-portrait__badge sobre-mi-portrait__badge--1">
        <span class="sobre-mi-portrait__badge-label">Desde</span>
        <span class="sobre-mi-portrait__badge-value"><strong>2019</strong></span>
      </div>
      <div class="sobre-mi-portrait__badge sobre-mi-portrait__badge--2">
        <span class="sobre-mi-portrait__badge-label">Grado</span>
        <span class="sobre-mi-portrait__badge-value">Ingeniería <strong>Informática</strong></span>
      </div>
      <div class="sobre-mi-portrait__badge sobre-mi-portrait__badge--3">
        <span class="sobre-mi-portrait__badge-label">Modelo</span>
        <span class="sobre-mi-portrait__badge-value">100% <strong>directo</strong></span>
      </div>
    </div>
  </SiteWrap>
</header>
