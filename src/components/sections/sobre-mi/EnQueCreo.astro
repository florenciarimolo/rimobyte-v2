---
import SectionShell from '../../ui/SectionShell.astro';
import SiteWrap from '../../ui/SiteWrap.astro';
import SectionHead from '../../ui/SectionHead.astro';
import { sobreMiBeliefs } from '../../../data/sobreMi';
---

<SectionShell transparent padding="home">
  <SiteWrap>
    <SectionHead
      pill="En qué creo"
      title="Cuatro principios que"
      titleGradient="guían cada proyecto."
      subtitle="Creo que una web bien hecha no es un gasto — es la única herramienta de ventas que trabaja por ti las 24 horas. Y creo que para que funcione, tiene que ser tuya de verdad. No tuya-entre-comillas, con el hosting a nombre de otro y un contrato de mantenimiento obligatorio. Tuya de verdad: con todos los accesos, en tu cuenta, bajo tu control."
      class="reveal"
      narrow={false}
    />

    <div class="principles principles--beliefs">
      {
        sobreMiBeliefs.map((belief) => (
          <article class="principle glass-card glass-card--hover reveal">
            <div class="principle__num">{belief.num}</div>
            <h3>{belief.title}</h3>
            <p>{belief.body}</p>
          </article>
        ))
      }
    </div>
  </SiteWrap>
</SectionShell>
