---
import Button from '../ui/Button.astro';
import SectionShell from '../ui/SectionShell.astro';
import SiteWrap from '../ui/SiteWrap.astro';
import SectionHead from '../ui/SectionHead.astro';
import { spotlightProjects } from '../../data/homeShowcase';
import { projects } from '../../data/projects';

const portfolioProjects = spotlightProjects.slice(0, 4).map((showcase) => {
  const project = projects.find((p) => p.slug === showcase.slug)!;
  return {
    ...showcase,
    location: project.location,
    href: `/proyectos/${project.slug}/`,
  };
});

const spans = ['portfolio-project--wide', 'portfolio-project--narrow', 'portfolio-project--narrow', 'portfolio-project--wide'];
---

<SectionShell id="proyectos" transparent padding="home" class="portfolio-section">
  <SiteWrap>
    <SectionHead
      pill="Portfolio · 9 negocios"
      title="Detrás de cada web, un negocio que"
      titleGradient="quería crecer."
      subtitle="Manicuras, sandalias artesanales, asesorías fiscales, campamentos de rock, ciberpsicología, cursos online. Cada proyecto cuenta una historia distinta."
      class="reveal"
    />

    <div class="portfolio-grid">
      {
        portfolioProjects.map((p, i) => (
          <a href={p.href} class:list={['portfolio-project reveal', spans[i]]}>
            <div
              class="portfolio-project__thumb"
              role="img"
              aria-label={`Captura de ${p.name}`}
              style={`background-image: url('${p.image}')`}
            />
            <div class="portfolio-project__info">
              <div>
                <h3>{p.name}</h3>
                <p>
                  {p.sector} · {p.location}
                </p>
              </div>
              <span class="portfolio-project__arrow" aria-hidden="true">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                  <path d="M5 12h14M13 5l7 7-7 7" />
                </svg>
              </span>
            </div>
          </a>
        ))
      }
    </div>

    <div class="portfolio-foot reveal">
      <Button href="/proyectos/" variant="outline">Ver los 9 proyectos →</Button>
    </div>
  </SiteWrap>
</SectionShell>
