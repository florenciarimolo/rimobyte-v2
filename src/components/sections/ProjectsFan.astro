---
import SectionShell from '../ui/SectionShell.astro';
import SiteWrap from '../ui/SiteWrap.astro';
import SectionHead from '../ui/SectionHead.astro';
import { spotlightProjects } from '../../data/homeShowcase';

const first = spotlightProjects[0];
---

<SectionShell id="proyectos">
  <SiteWrap>
    <SectionHead
      title="Proyectos recientes"
      subtitle="Negocios locales que querían ser encontrados, crecer o vender online."
      class="reveal"
    />

    <article class="work-spotlight reveal" id="work-spotlight">
      <div class="work-spotlight__media">
        <img
          id="work-spotlight-img"
          src={first.image}
          alt={first.name}
          width="720"
          height="450"
        />
      </div>
      <div class="work-spotlight__body">
        <span class="work-spotlight__sector" id="work-spotlight-sector">{first.sector}</span>
        <h3 class="work-spotlight__name" id="work-spotlight-name">{first.name}</h3>
        <p class="work-spotlight__desc" id="work-spotlight-desc">{first.description}</p>
        <a
          href={`https://${first.url}`}
          class="work-spotlight__link"
          id="work-spotlight-link"
          target="_blank"
          rel="noopener noreferrer"
        >
          {first.url} ↗
        </a>
      </div>
    </article>

    <div class="work-picker" id="work-picker" role="tablist" aria-label="Seleccionar proyecto">
      {spotlightProjects.map((p, i) => (
        <button
          type="button"
          class:list={['work-picker__btn', i === 0 && 'is-active']}
          role="tab"
          aria-selected={i === 0 ? 'true' : 'false'}
          data-img={p.image}
          data-name={p.name}
          data-sector={p.sector}
          data-url={p.url}
          data-desc={p.description}
        >
          <span class="work-picker__idx">{String(i + 1).padStart(2, '0')}</span>
          <span class="work-picker__label">{p.name}</span>
        </button>
      ))}
    </div>

    <a href="/proyectos/" class="hero-showcase__more work-section__more reveal">Ver todos los proyectos →</a>
  </SiteWrap>
</SectionShell>
