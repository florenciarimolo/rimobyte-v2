---
import Eyebrow from '../ui/Eyebrow.astro';

/* Orden del abanico: Vila i Lancis en el centro (índice 2) */
const projects = [
  { name: 'Lucía Nails Art', sector: 'Estética',       slug: 'lucia-nails-art', url: 'lucianailsart.com' },
  { name: 'Rock Zone Camp',  sector: 'Música',         slug: 'rock-zone-camp',  url: 'rockzonecamp.com' },
  { name: 'Vila i Lancis',   sector: 'Asesoría',       slug: 'vila-i-lancis',   url: 'vilalancis.com' },
  { name: 'Ariadna Vilalta', sector: 'Ciberpsicóloga', slug: 'ariadna-vilalta', url: 'ariadnavilalta.com' },
  { name: 'de Cos',          sector: 'Tienda online',  slug: 'de-cos',          url: 'decos.es' },
];

const imageMap: Record<string, string> = {
  'vila-i-lancis':   '/assets/projects/vila-lancis-v2.webp',
  'lucia-nails-art': '/assets/projects/lucia-nails.webp',
  'rock-zone-camp':  '/assets/projects/rockzone.webp',
  'ariadna-vilalta': '/assets/projects/ariadna-vilalta.webp',
  'de-cos':          '/assets/projects/decos.webp',
};

/* Abanico en W: inclinación hacia el centro, centro más alto */
const fanAngles  = [-9, -4, 0, 4, 9];
const fanOffsetX = [-480, -240, 0, 240, 480];
const fanOffsetY = [20, 10, 0, 10, 20];
const fanZIndex  = [1, 2, 5, 2, 1];

function fanTransform(i: number, straight = false) {
  const rotate = straight ? 0 : fanAngles[i];
  return `translateX(calc(-50% + ${fanOffsetX[i]}px)) translateY(${fanOffsetY[i]}px) rotate(${rotate}deg)`;
}
---

<section class="section-bg pt-[clamp(4rem,8vw,7rem)] pb-[clamp(5rem,10vw,9rem)]">
  <div class="max-w-[1200px] mx-auto px-[clamp(1.5rem,5vw,4rem)]">

    <header class="reveal flex flex-wrap items-end justify-between gap-6 mb-10 md:mb-14">
      <div class="max-w-[560px]">
        <Eyebrow text="PORTFOLIO · 9 PROYECTOS" />
        <h2 class="text-[clamp(2rem,3.5vw,3rem)] leading-[1.08] tracking-[-0.025em]">
          Proyectos <em>destacados.</em>
        </h2>
        <p class="mt-4 text-base leading-[1.75] text-(--color-text-secondary)">
          Cada web que entrego tiene detrás una historia: un negocio que quería crecer, un autónomo que quería ser encontrado, o una tienda que quería vender online. Aquí van algunos de ellos.
        </p>
      </div>
      <a href="/proyectos" class="projects-fan__link projects-fan__link--desktop">
        Ver todos <span aria-hidden="true">→</span>
      </a>
    </header>

  </div>

  <div
    id="fan-container"
    class="projects-fan__stage reveal"
    data-transforms={JSON.stringify(projects.map((_, i) => fanTransform(i)))}
    data-straight={JSON.stringify(projects.map((_, i) => fanTransform(i, true)))}
    data-zindex={JSON.stringify(fanZIndex)}
  >
    {projects.map((p, i) => {
      const img = imageMap[p.slug];
      return (
        <a
          href={`/proyectos/${p.slug}`}
          class="fan-card"
          style={`
            transform: ${fanTransform(i)};
            z-index: ${fanZIndex[i]};
          `}
        >
          <div class="fan-card__media">
            {img ? (
              <img
                src={img}
                alt={`Captura de ${p.name}`}
                class="fan-card__img"
                loading="lazy"
                decoding="async"
              />
            ) : (
              <div class="fan-card__placeholder">{p.name}</div>
            )}
          </div>
          <div class="fan-card__info">
            <p class="fan-card__sector">{p.sector}</p>
            <p class="fan-card__name">{p.name}</p>
            <p class="fan-card__url">{p.url}</p>
          </div>
        </a>
      );
    })}
  </div>

  <div class="projects-fan__scroll reveal">
    {projects.map((p) => {
      const img = imageMap[p.slug];
      return (
        <a href={`/proyectos/${p.slug}`} class="fan-card">
          <div class="fan-card__media">
            {img ? (
              <img
                src={img}
                alt={`Captura de ${p.name}`}
                class="fan-card__img"
                loading="lazy"
                decoding="async"
              />
            ) : (
              <div class="fan-card__placeholder">{p.name}</div>
            )}
          </div>
          <div class="fan-card__info">
            <p class="fan-card__sector">{p.sector}</p>
            <p class="fan-card__name">{p.name}</p>
            <p class="fan-card__url">{p.url}</p>
          </div>
        </a>
      );
    })}
  </div>

  <div class="projects-fan__mobile-cta reveal">
    <a href="/proyectos" class="projects-fan__link">
      Ver todos <span aria-hidden="true">→</span>
    </a>
  </div>
</section>

<script>
  const container = document.getElementById('fan-container');
  if (container) {
    const cards = container.querySelectorAll<HTMLElement>('.fan-card');
    const transforms = JSON.parse(container.dataset.transforms ?? '[]') as string[];
    const straightTransforms = JSON.parse(container.dataset.straight ?? '[]') as string[];
    const zIndexes = JSON.parse(container.dataset.zindex ?? '[]') as number[];

    cards.forEach((card, i) => {
      card.addEventListener('mouseenter', () => {
        card.style.transform = straightTransforms[i];
        card.style.zIndex = '20';
        card.classList.add('is-straight');
      });

      card.addEventListener('mouseleave', () => {
        card.style.transform = transforms[i];
        card.style.zIndex = String(zIndexes[i]);
        card.classList.remove('is-straight');
      });
    });
  }
</script>
