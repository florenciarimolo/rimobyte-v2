---
import AuthorCard from '../../ui/AuthorCard.astro';
---

<section class="section-bg--elevated py-[clamp(3rem,6vw,5rem)]">
  <div
    class="article-layout max-w-layout mx-auto px-[clamp(1.5rem,5vw,4rem)] grid gap-10 lg:gap-12 lg:grid-cols-[minmax(0,1fr)_240px]"
  >
    <article class="prose-rimobyte reveal max-w-[720px] w-full mx-auto lg:mx-0">
      <slot />
    </article>

    <div class="article-layout__aside lg:block">
      <div class="article-layout__sticky">
        <AuthorCard />
      </div>
    </div>
  </div>
</section>

<style>
  .article-layout__sticky {
    position: sticky;
    top: calc(var(--nav-height, 80px) + 1.5rem);
  }
</style>

<style is:global>
  /* Tipografía editorial para contenido de blog */
  .prose-rimobyte {
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.8;
    color: var(--color-text-primary);
  }

  /* Anular degradado global de h1/h2 (.headline-gradient) en titulares del artículo */
  .prose-rimobyte h2,
  .prose-rimobyte h3 {
    background: none;
    background-image: none;
    -webkit-background-clip: border-box;
    background-clip: border-box;
    -webkit-text-fill-color: var(--color-blue);
    color: var(--color-blue);
    padding-top: 0;
    padding-bottom: 0;
    overflow: visible;
  }

  .prose-rimobyte h2 em,
  .prose-rimobyte h3 em {
    background: none;
    background-image: none;
    -webkit-background-clip: border-box;
    background-clip: border-box;
    -webkit-text-fill-color: var(--color-blue);
    color: var(--color-blue);
    font-style: italic;
    font-weight: inherit;
    padding: 0;
    margin: 0;
    isolation: auto;
    position: static;
    z-index: auto;
    -webkit-box-decoration-break: initial;
    box-decoration-break: initial;
  }

  .prose-rimobyte h2 {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1.5rem, 2.5vw, 1.875rem);
    line-height: 1.2;
    letter-spacing: -0.02em;
    margin-top: 3rem;
    margin-bottom: 1.25rem;
  }

  .prose-rimobyte h3 {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1.25rem, 2vw, 1.5rem);
    line-height: 1.3;
    letter-spacing: -0.01em;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }

  .prose-rimobyte p {
    margin-bottom: 1.5rem;
  }

  .prose-rimobyte strong {
    color: var(--color-text-primary);
    font-weight: 500;
  }

  .prose-rimobyte a {
    color: var(--color-blue);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: rgba(43, 71, 236, 0.35);
    transition: text-decoration-color 0.2s ease;
  }
  .prose-rimobyte a:hover {
    text-decoration-color: var(--color-blue);
  }

  .prose-rimobyte ul,
  .prose-rimobyte ol {
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
  }

  .prose-rimobyte ul {
    list-style-type: disc;
    list-style-position: outside;
  }

  .prose-rimobyte ol {
    list-style-type: decimal;
    list-style-position: outside;
  }

  .prose-rimobyte li {
    margin-bottom: 0.5rem;
    padding-left: 0.35rem;
  }

  .prose-rimobyte ul li::marker {
    color: var(--color-blue);
    font-size: 1.05em;
  }

  .prose-rimobyte ol li::marker {
    color: var(--color-blue);
    font-family: var(--font-mono);
    font-size: 0.875rem;
  }

  .prose-rimobyte blockquote {
    border-left: 3px solid var(--color-blue);
    padding-left: 1.25rem;
    margin: 2rem 0;
    font-style: italic;
    color: var(--color-text-primary);
  }

  .prose-rimobyte code {
    font-family: var(--font-mono);
    font-size: 0.875em;
    color: var(--color-blue);
    background: rgba(43, 71, 236, 0.08);
    padding: 0.15em 0.4em;
    border-radius: 4px;
  }

  .prose-rimobyte pre {
    background: var(--color-bg-surface);
    border: 1px solid var(--color-border-default);
    border-radius: 14px;
    padding: 1.25rem;
    overflow-x: auto;
    margin: 2rem 0;
  }
  .prose-rimobyte pre code {
    background: none;
    padding: 0;
    color: var(--color-text-secondary);
  }

  .prose-rimobyte hr {
    border: none;
    border-top: 1px solid var(--color-border-default);
    margin: 3rem 0;
  }

  /* Primera letra del artículo — detalle editorial */
  .prose-rimobyte > p:first-of-type::first-letter {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 3.5em;
    line-height: 0.8;
    float: left;
    margin-right: 0.1em;
    margin-top: 0.1em;
    color: var(--color-blue);
  }
</style>
