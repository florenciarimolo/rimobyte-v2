---
import SiteWrap from '../../ui/SiteWrap.astro';
import { blogTypeLabels, formatBlogDate, type BlogType } from '../../../data/blogMeta';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const type = post.data.type as BlogType;
---

<header class="blog-article-header">
  <SiteWrap>
    <div class="blog-meta-row reveal">
      <span class="cat">{blogTypeLabels[type]}</span>
      <span class="dot-sep" aria-hidden="true"></span>
      <span>{formatBlogDate(post.data.date, 'long')}</span>
      <span class="dot-sep" aria-hidden="true"></span>
      <span>{post.data.readingTime} de lectura</span>
    </div>
    <h1 class="reveal">{post.data.title}</h1>
    <p class="blog-article-lede reveal">{post.data.description}</p>
    <div class="blog-article-author reveal">
      <div class="blog-author-avatar" aria-hidden="true">FR</div>
      <div class="blog-author-info">
        <strong>Flor Rímolo</strong>
        <span>Ingeniera informática · RimoByte</span>
      </div>
    </div>
  </SiteWrap>
</header>
