---
import BlogCoverVisual from '../../ui/BlogCoverVisual.astro';
import SiteWrap from '../../ui/SiteWrap.astro';
import { blogTypeLabels, formatBlogDate, type BlogType } from '../../../data/blogMeta';
import type { CollectionEntry } from 'astro:content';

interface Props {
  posts: CollectionEntry<'blog'>[];
}

const { posts } = Astro.props;
---

<section class="blog-related">
  <SiteWrap>
    <div class="blog-related-head reveal">
      <h2>Sigue leyendo</h2>
    </div>
    <div class="blog-related-grid">
      {
        posts.map((post) => {
          const type = post.data.type as BlogType;
          return (
            <a href={`/blog/${post.id}/`} class="blog-related-card reveal">
              <BlogCoverVisual
                slug={post.id}
                coverImage={post.data.coverImage}
                title={post.data.title}
                type={type}
                variant="related"
                showTag={false}
              />
              <div class="blog-related-info">
                <div class="blog-meta-row">
                  <span class="cat">{blogTypeLabels[type]}</span>
                  <span class="dot-sep" aria-hidden="true"></span>
                  <span>{formatBlogDate(post.data.date)}</span>
                  <span class="dot-sep" aria-hidden="true"></span>
                  <span>{post.data.readingTime}</span>
                </div>
                <h3>{post.data.title}</h3>
                <p>{post.data.description}</p>
              </div>
            </a>
          );
        })
      }
    </div>
  </SiteWrap>
</section>
