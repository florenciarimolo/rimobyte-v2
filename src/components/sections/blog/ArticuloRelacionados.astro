---
import BlogCard from '../../ui/BlogCard.astro';
import Eyebrow from '../../ui/Eyebrow.astro';
import SectionShell from '../../ui/SectionShell.astro';
import SiteWrap from '../../ui/SiteWrap.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  posts: CollectionEntry<'blog'>[];
}

const { posts } = Astro.props;
---

<SectionShell padding="none" class="py-[clamp(5rem,9vw,7rem)]">
  <SiteWrap>
    <div class="reveal mb-8">
      <Eyebrow text="SIGUE LEYENDO" class="mb-4" />
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      {
        posts.map((post) => (
          <BlogCard
            slug={post.id}
            title={post.data.title}
            description={post.data.description}
            date={post.data.date}
            type={post.data.type}
            readingTime={post.data.readingTime}
          />
        ))
      }
    </div>
  </SiteWrap>
</SectionShell>
