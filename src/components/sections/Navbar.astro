---
import Button from '../ui/Button.astro';
import SiteWrap from '../ui/SiteWrap.astro';
import ThemeSwitcher from '../ui/ThemeSwitcher.astro';
import chevronDownSvg from '../ui/icons/chevron-down.svg?raw';
import { SERVICE_NAV_LINKS } from '../../data/navigation';

const navLinkClass =
  'font-body text-sm text-text-secondary no-underline hover:text-text-primary transition-colors duration-200';

const navChevronClass =
  'icon inline-flex size-5 shrink-0 text-text-secondary pointer-events-none transition-transform duration-200 [&_svg]:size-full';
---

<header class="site-nav" id="navbar">
  <div class="site-nav__bar">
    <SiteWrap class="site-nav__inner">
      <a href="/" class="site-nav__logo">
        Rimo<span class="text-gradient-logo">Byte</span>
      </a>

      <nav class="site-nav__links" aria-label="Principal">
        <a href="/proyectos/" class={navLinkClass}>Proyectos</a>

        <div class="relative">
          <details id="nav-services-desktop" class="group/nav-services">
            <summary
              class:list={[
                navLinkClass,
                'cursor-pointer list-none inline-flex items-center gap-1.5 select-none',
                '[&::-webkit-details-marker]:hidden',
              ]}
            >
              Servicios
              <span
                class:list={[navChevronClass, 'group-open/nav-services:rotate-180']}
                aria-hidden="true"
                set:html={chevronDownSvg}
              />
            </summary>
            <div class="absolute left-0 top-full z-60 pt-2 min-w-54">
              <div
                class="nav-dropdown flex flex-col rounded-xl border border-border-default bg-bg-elevated/95 backdrop-blur-md py-2"
                role="group"
                aria-label="Servicios"
              >
                {SERVICE_NAV_LINKS.map(({ label, href }) => (
                  <a
                    href={href}
                    class="px-4 py-2.5 text-sm text-text-secondary no-underline hover:text-text-primary hover:bg-bg-subtle transition-colors duration-150"
                  >
                    {label}
                  </a>
                ))}
              </div>
            </div>
          </details>
        </div>

        <a href="/blog/" class={navLinkClass}>Blog</a>
        <a href="/sobre-mi/" class={navLinkClass}>Sobre mí</a>
      </nav>

      <div class="site-nav__actions">
        <ThemeSwitcher />
        <div class="hidden md:block">
          <Button href="/contacto/" variant="primary">Empezar mi web</Button>
        </div>
        <button
          type="button"
          class="site-nav__burger md:hidden"
          id="menu-btn"
          aria-label="Abrir menú"
          aria-expanded="false"
          aria-controls="nav-drawer"
        >
          <span></span><span></span>
        </button>
      </div>
    </SiteWrap>
  </div>
  <div class="site-nav__progress" id="nav-progress" aria-hidden="true"></div>
</header>

<div class="site-nav__drawer" id="nav-drawer" hidden inert>
  <nav aria-label="Menú móvil">
    <a href="/proyectos/">Proyectos</a>

    <details id="nav-services-mobile" class="group/nav-services-mobile">
      <summary class="cursor-pointer list-none inline-flex items-center gap-2 [&::-webkit-details-marker]:hidden">
        Servicios
        <span
          class:list={[navChevronClass, 'group-open/nav-services-mobile:rotate-180']}
          aria-hidden="true"
          set:html={chevronDownSvg}
        />
      </summary>
      <div class="mt-4 flex flex-col gap-3 pl-1">
        {SERVICE_NAV_LINKS.map(({ label, href }) => (
          <a href={href} class="font-body text-lg text-text-secondary no-underline hover:text-text-primary transition-colors">
            {label}
          </a>
        ))}
      </div>
    </details>

    <a href="/blog/">Blog</a>
    <a href="/sobre-mi/">Sobre mí</a>
    <a href="/contacto/">Contacto</a>
  </nav>
</div>

<script>
  const menuBtn = document.getElementById('menu-btn') as HTMLButtonElement;
  const drawer = document.getElementById('nav-drawer') as HTMLElement;
  const desktopServices = document.getElementById('nav-services-desktop') as HTMLDetailsElement | null;
  let menuOpen = false;

  function setMenu(open: boolean) {
    menuOpen = open;
    drawer.hidden = !open;
    drawer.inert = !open;
    drawer.classList.toggle('is-open', open);
    menuBtn?.classList.toggle('is-open', open);
    menuBtn?.setAttribute('aria-expanded', String(open));
    menuBtn?.setAttribute('aria-label', open ? 'Cerrar menú' : 'Abrir menú');
    document.body.style.overflow = open ? 'hidden' : '';
  }

  menuBtn?.addEventListener('click', () => setMenu(!menuOpen));
  drawer?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => setMenu(false));
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && menuOpen) setMenu(false);
  });

  document.addEventListener('click', (e) => {
    if (!desktopServices?.open) return;
    const t = e.target as Node;
    if (!desktopServices.contains(t)) desktopServices.open = false;
  });

  desktopServices?.querySelectorAll('a').forEach((a) => {
    a.addEventListener('click', () => {
      desktopServices.open = false;
    });
  });
</script>
