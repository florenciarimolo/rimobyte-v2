---
import Stars from '../../ui/Stars.astro';
import SiteWrap from '../../ui/SiteWrap.astro';

interface Props {
  testimonial: { quote: string; quoteHighlight?: string; author: string; role?: string };
  projectUrl: string;
  authorInitial?: string;
}

const { testimonial, projectUrl, authorInitial } = Astro.props;
const initial = authorInitial ?? testimonial.author.charAt(0).toUpperCase();
const role = testimonial.role ?? `${projectUrl}`;

function renderQuote(quote: string, quoteHighlight?: string) {
  if (!quoteHighlight) return quote;

  const idx = quote.indexOf(quoteHighlight);
  if (idx === -1) return quote;

  return {
    before: quote.slice(0, idx),
    highlight: quoteHighlight,
    after: quote.slice(idx + quoteHighlight.length).replace(/^\s+([.,!?…])/u, '$1'),
  };
}

const renderedQuote = renderQuote(testimonial.quote, testimonial.quoteHighlight);
---

<section class="project-quote-v6" aria-label="Testimonio del cliente">
  <SiteWrap>
    <figure class="project-quote-v6__card reveal">
      <Stars />
      <blockquote>"{typeof renderedQuote === 'string' ? renderedQuote : (<>{renderedQuote.before}<span class="gradient-text">{renderedQuote.highlight}</span>{renderedQuote.after}</>)}"
</blockquote>
      <figcaption class="project-quote-v6__author">
        <div class="project-quote-v6__avatar" aria-hidden="true">{initial}</div>
        <div class="project-quote-v6__author-info">
          <strong>{testimonial.author}</strong>
          <span>{role}</span>
        </div>
      </figcaption>
    </figure>
  </SiteWrap>
</section>
