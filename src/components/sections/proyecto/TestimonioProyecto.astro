---
import QuoteIcon from '../../ui/QuoteIcon.astro';
import SectionShell from '../../ui/SectionShell.astro';
import SiteWrap from '../../ui/SiteWrap.astro';

interface Props {
  testimonial: { quote: string; author: string };
  /** Dominio público del proyecto (ej. decos.es) */
  projectUrl: string;
}

const { testimonial, projectUrl } = Astro.props;
---
<SectionShell elevated padding="none" class="py-[clamp(5rem,9vw,7rem)]">
  <SiteWrap class="max-w-[900px] text-center">

    <div class="reveal mb-6 flex justify-center text-blue opacity-70">
      <QuoteIcon variant="ornate" tone="strong" size="xl" />
    </div>

    <blockquote class="reveal font-display font-medium italic
                       text-[clamp(1.5rem,3vw,2.25rem)] leading-[1.35] tracking-[-0.015em]
                       text-text-primary mb-8 m-0">
      "{testimonial.quote}"
    </blockquote>

    <p class="reveal font-mono text-xs tracking-[0.12em] uppercase
              text-text-secondary m-0">
      — {testimonial.author}
      <span class="text-text-muted"> · {projectUrl}</span>
    </p>

  </SiteWrap>
</SectionShell>
