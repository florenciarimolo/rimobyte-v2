---
import Pill from '../../ui/Pill.astro';
import SiteWrap from '../../ui/SiteWrap.astro';
import type { ProjectStat } from '../../../data/projects';

interface Props {
  stats: ProjectStat[];
}

const { stats } = Astro.props;
---

<section class="project-results-v6" aria-label="Resultados del proyecto">
  <SiteWrap>
    <Pill text="Resultados de un vistazo" class="mb-6 reveal" />
    <div class="project-results-v6__grid">
      {
        stats.map((stat) => (
          <div class="project-result-card reveal">
            <div class="project-result-card__label">{stat.label}</div>
            <div class="project-result-card__num gradient-text">{stat.value}</div>
            {stat.description ? <p class="project-result-card__desc">{stat.description}</p> : null}
          </div>
        ))
      }
    </div>
  </SiteWrap>
</section>
