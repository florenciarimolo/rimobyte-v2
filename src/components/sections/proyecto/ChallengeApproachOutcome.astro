---
import type { Project } from '../../../data/projects';
import SectionShell from '../../ui/SectionShell.astro';
import SiteWrap from '../../ui/SiteWrap.astro';

interface Props {
  project: Project;
}

const { project } = Astro.props;

const blocks = [
  { title: 'El desafío', body: project.challenge },
  { title: 'La propuesta', body: project.solution },
  { title: 'El resultado', body: project.result },
];
---
<SectionShell padding="none" class="py-[clamp(5rem,9vw,7rem)]">
  <SiteWrap>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 md:gap-[clamp(2rem,4vw,3rem)]">
      {blocks.map((block) => (
        <div class="reveal">
          <h2 class="title-accent headline-gradient font-display font-medium
                     text-[clamp(1.5rem,2.4vw,1.75rem)] leading-[1.2] tracking-[-0.02em] mb-5">
            {block.title}
          </h2>
          <p class="font-body text-[0.9375rem] leading-[1.75] text-text-secondary m-0">
            {block.body}
          </p>
        </div>
      ))}
    </div>

  </SiteWrap>
</SectionShell>
