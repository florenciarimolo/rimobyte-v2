---
import type { Project } from '../../../data/projects';
import Eyebrow from '../../ui/Eyebrow.astro';

interface Props {
  nextProject: Project;
  prevProject: Project;
}

const { nextProject, prevProject } = Astro.props;
---
<section class="section-bg py-[clamp(5rem,9vw,7rem)]">
  <div class="max-w-layout mx-auto px-[clamp(1.5rem,5vw,4rem)]">

    <div class="reveal mb-12">
      <Eyebrow text="MÁS PROYECTOS" />
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-8">

      <a href={`/proyectos/${prevProject.slug}/`}
         class="nextprev-card reveal group flex flex-col gap-5 no-underline text-inherit text-left">
        <div class="nextprev-card__label inline-flex items-center gap-2 font-mono
                    text-[0.6875rem] tracking-[0.12em] uppercase text-text-muted">
          <span aria-hidden="true">←</span>
          <span>Proyecto anterior</span>
        </div>
        <div class="nextprev-card__media aspect-16/10 rounded-[14px] overflow-hidden
                    border border-border-default">
          <img
            src={prevProject.image}
            alt={`Captura de ${prevProject.name}`}
            loading="lazy"
            decoding="async"
            class="w-full h-full object-cover object-top block"
          />
        </div>
        <div>
          <Eyebrow text={prevProject.eyebrow} class="mb-3" />
          <h3 class="font-display font-medium text-[clamp(1.25rem,2vw,1.5rem)]
                     leading-tight tracking-[-0.02em] text-text-primary m-0">
            {prevProject.displayName}
          </h3>
        </div>
      </a>

      <a href={`/proyectos/${nextProject.slug}/`}
         class="nextprev-card reveal group flex flex-col gap-5 no-underline text-inherit text-left md:text-right md:items-end">
        <div class="nextprev-card__label inline-flex items-center gap-2 font-mono
                    text-[0.6875rem] tracking-[0.12em] uppercase text-text-muted
                    md:order-1">
          <span>Siguiente proyecto</span>
          <span aria-hidden="true">→</span>
        </div>
        <div class="nextprev-card__media aspect-16/10 rounded-[14px] overflow-hidden
                    border border-border-default w-full md:order-2">
          <img
            src={nextProject.image}
            alt={`Captura de ${nextProject.name}`}
            loading="lazy"
            decoding="async"
            class="w-full h-full object-cover object-top block"
          />
        </div>
        <div class="md:max-w-full md:order-3 md:flex md:flex-col md:items-end">
          <div class="mb-3 md:flex md:w-full md:justify-end">
            <Eyebrow text={nextProject.eyebrow} />
          </div>
          <h3 class="font-display font-medium text-[clamp(1.25rem,2vw,1.5rem)]
                     leading-tight tracking-[-0.02em] text-text-primary m-0">
            {nextProject.displayName}
          </h3>
        </div>
      </a>

    </div>

  </div>
</section>

<style>
  .nextprev-card__media img {
    transition: transform 0.6s var(--ease-spring);
  }

  .nextprev-card__media {
    transition: border-color 0.3s var(--ease-spring);
  }

  .nextprev-card:hover .nextprev-card__media {
    border-color: var(--color-border-blue);
  }

  .nextprev-card:hover .nextprev-card__media img {
    transform: scale(1.04);
  }

  .nextprev-card__label {
    transition: gap 0.2s ease, color 0.2s ease;
  }

  .nextprev-card:hover .nextprev-card__label {
    gap: 0.75rem;
    color: var(--color-blue);
  }
</style>
