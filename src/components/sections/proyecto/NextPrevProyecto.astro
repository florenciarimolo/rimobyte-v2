---
import Button from '../../ui/Button.astro';
import Icon from '../../ui/Icon.astro';
import ProjectOtherThumb from '../../ui/ProjectOtherThumb.astro';
import SiteWrap from '../../ui/SiteWrap.astro';
import { projectCount, type Project } from '../../../data/projects';

interface Props {
  nextProject: Project;
  prevProject: Project;
}

const { nextProject, prevProject } = Astro.props;
---

<section class="project-other-v6" aria-label="Más proyectos">
  <SiteWrap>
    <div class="project-other-v6__head reveal">
      <h2>Más proyectos</h2>
      <Button href="/proyectos/" variant="ghost">
        Ver los {projectCount} proyectos
        <Icon name="arrow-right" />
      </Button>
    </div>

    <div class="project-other-v6__grid">
      <a href={`/proyectos/${prevProject.slug}/`} class="project-other-v6__card reveal">
        <ProjectOtherThumb project={prevProject} />
        <div>
          <div class="project-other-v6__label">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <path d="M19 12H5M12 19l-7-7 7-7" />
            </svg>
            Proyecto anterior
          </div>
          <h4>{prevProject.displayName}</h4>
        </div>
      </a>

      <a
        href={`/proyectos/${nextProject.slug}/`}
        class="project-other-v6__card project-other-v6__card--next reveal"
      >
        <ProjectOtherThumb project={nextProject} />
        <div>
          <div class="project-other-v6__label">
            Siguiente proyecto
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <path d="M5 12h14M13 5l7 7-7 7" />
            </svg>
          </div>
          <h4>{nextProject.displayName}</h4>
        </div>
      </a>
    </div>
  </SiteWrap>
</section>
