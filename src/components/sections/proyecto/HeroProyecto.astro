---
import Button from '../../ui/Button.astro';
import Icon from '../../ui/Icon.astro';
import Pill from '../../ui/Pill.astro';
import ProjectHeroShot from '../../ui/ProjectHeroShot.astro';
import SiteWrap from '../../ui/SiteWrap.astro';
import {
  projectYear,
  splitDisplayNameHighlight,
  type Project,
} from '../../../data/projects';

interface Props {
  project: Project;
}

const { project } = Astro.props;
const heroImg = project.heroImage ?? project.image;
const titleParts = splitDisplayNameHighlight(project.displayName, project.displayNameHighlight);
const externalUrl = `https://${project.url}`;
const year = projectYear(project.date);
const metaPill = project.stackLabel ? `${year} · ${project.stackLabel}` : year;
const lede =
  project.heroLede ??
  `${project.challenge.split('.')[0]?.trim() ?? project.challenge}.`;
---

<header class="project-detail-hero">
  <SiteWrap>
    <div class="project-detail-hero__meta reveal">
      <Pill text={project.eyebrow} />
      <Pill>{metaPill}</Pill>
    </div>

    <h1 class="reveal">
      {
        titleParts ? (
          <>
            {titleParts.before}
            <span class="gradient-text">{titleParts.em}</span>
            {titleParts.after}
          </>
        ) : (
          project.displayName
        )
      }
    </h1>

    <p class="project-detail-hero__lede reveal">{lede}</p>

    <div class="project-detail-hero__cta reveal">
      <Button href={externalUrl} variant="primary" external>
        Visitar {project.url}
        <Icon name="arrow-up-right" />
      </Button>
      <Button href="#story" variant="ghost">Leer el caso completo</Button>
    </div>

    <ProjectHeroShot
      class="reveal"
      url={project.url}
      image={heroImg}
      alt={`Captura de la web ${project.name}`}
      thumbGradient={project.thumbGradient}
    />
  </SiteWrap>
</header>
