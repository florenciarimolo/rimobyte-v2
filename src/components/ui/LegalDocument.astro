---
import Pill from './Pill.astro';
import SiteWrap from './SiteWrap.astro';

interface Props {
  title: string;
  description: string;
  pill: string;
}

const { title, description, pill } = Astro.props;
---

<section class="legal-v6">
  <header class="legal-v6__header">
    <SiteWrap>
      <Pill class="reveal">{pill}</Pill>
      <h1 class="reveal">{title}</h1>
      <p class="legal-v6__lede reveal">{description}</p>
    </SiteWrap>
  </header>

  <SiteWrap>
    <article class="legal-v6__body reveal">
      <slot />
    </article>
  </SiteWrap>
</section>
