---
import SectionShell from './SectionShell.astro';
import SiteWrap from './SiteWrap.astro';

interface Props {
  title: string;
  description: string;
  eyebrow: string;
}

const { title, description, eyebrow } = Astro.props;
---

<SectionShell padding="none" class="py-[clamp(4rem,8vw,7rem)] min-h-[50vh]">
  <SiteWrap>
    <p class="eyebrow">
      <span class="eyebrow__bracket" aria-hidden="true">[</span>
      {eyebrow}
      <span class="eyebrow__bracket" aria-hidden="true">]</span>
    </p>
    <h1 class="text-[clamp(2rem,4vw,2.75rem)] leading-[1.1] tracking-[-0.03em] mb-4 max-w-3xl">
      {title}
    </h1>
    <p class="text-text-secondary text-base max-w-2xl mb-10 leading-relaxed">
      {description}
    </p>
    <div
      class:list={[
        'legal-document max-w-2xl space-y-6 text-[0.9375rem] leading-[1.75] text-text-secondary',
        '[&_h3]:text-[1.125rem] [&_h3]:mt-10 [&_h3]:mb-3 [&_h3]:text-text-primary [&_h3]:font-medium [&_h3]:tracking-[-0.02em] [&_h3:first-child]:mt-0',
        '[&_ul]:list-disc [&_ul]:pl-5 [&_ul]:space-y-2',
        '[&_ol]:list-decimal [&_ol]:pl-5 [&_ol]:space-y-2',
        '[&_a]:text-blue [&_a]:underline [&_a]:underline-offset-2 [&_a]:hover:text-blue-hover [&_a]:transition-colors',
        '[&_strong]:text-text-primary [&_strong]:font-medium',
      ]}
    >
      <slot />
    </div>
  </SiteWrap>
</SectionShell>
