---
/** Mockup de especialidades / primera cita para landings sector psicología (reutiliza estilos de carta). */
---

<div class="sector-menu-mockup">
  <div class="sector-menu-mockup__paper">
    <div class="sector-menu-mockup__header">
      <h4>
        <em>Áreas</em> de tratamiento
      </h4>
      <p>Adultos · Pareja · Online</p>
    </div>

    <div class="sector-menu-mockup__section">
      <div class="sector-menu-mockup__section-label">Individual</div>
      <div class="sector-menu-mockup__item">
        <div class="sector-menu-mockup__item-name">
          Ansiedad y estrés
          <small>primera sesión 60 min</small>
        </div>
        <div class="sector-menu-mockup__item-dots" aria-hidden="true"></div>
        <div class="sector-menu-mockup__item-price">Online</div>
      </div>
      <div class="sector-menu-mockup__item">
        <div class="sector-menu-mockup__item-name">
          Depresión y duelo
          <small>enfoque cognitivo-conductual</small>
        </div>
        <div class="sector-menu-mockup__item-dots" aria-hidden="true"></div>
        <div class="sector-menu-mockup__item-price">Presencial</div>
      </div>
    </div>

    <div class="sector-menu-mockup__section">
      <div class="sector-menu-mockup__section-label">Pareja y familia</div>
      <div class="sector-menu-mockup__item">
        <div class="sector-menu-mockup__item-name">
          Terapia de pareja
          <small>sesión conjunta 75 min</small>
        </div>
        <div class="sector-menu-mockup__item-dots" aria-hidden="true"></div>
        <div class="sector-menu-mockup__item-price">Híbrido</div>
      </div>
    </div>

    <div class="sector-menu-mockup__cta">Pedir primera cita →</div>
  </div>
</div>
