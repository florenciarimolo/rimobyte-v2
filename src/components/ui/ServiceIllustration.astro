---
interface Props {
  variant: 'corporate' | 'ecommerce' | 'maintenance';
  class?: string;
}

const { variant, class: className = '' } = Astro.props;
---

{variant === 'corporate' && (
  <div class:list={['service-illustration', className]} aria-hidden="true">
    <svg class="svc-illus-svg" width="100%" viewBox="0 0 420 340" fill="none" xmlns="http://www.w3.org/2000/svg">
      <g class="svc-illus-grid" opacity="0.04" stroke="#2B47EC" stroke-width="0.5">
        <line x1="0" y1="0" x2="0" y2="340" />
        <line x1="52" y1="0" x2="52" y2="340" />
        <line x1="104" y1="0" x2="104" y2="340" />
        <line x1="156" y1="0" x2="156" y2="340" />
        <line x1="208" y1="0" x2="208" y2="340" />
        <line x1="260" y1="0" x2="260" y2="340" />
        <line x1="312" y1="0" x2="312" y2="340" />
        <line x1="364" y1="0" x2="364" y2="340" />
        <line x1="420" y1="0" x2="420" y2="340" />
      </g>

      <g class="svc-illus-rings">
        <circle cx="350" cy="48" r="60" stroke="#2B47EC" stroke-width="0.5" opacity="0.06" />
        <circle cx="350" cy="48" r="40" stroke="#2B47EC" stroke-width="0.5" opacity="0.08" />
        <circle cx="350" cy="48" r="20" stroke="#2B47EC" stroke-width="0.5" opacity="0.1" />
      </g>

      <g class="svc-illus-float-slow">
        <rect width="80" height="128" rx="10" stroke="rgba(43,71,236,0.22)" stroke-width="0.5" />
        <rect x="10" y="10" width="60" height="8" rx="4" fill="rgba(43,71,236,0.12)" />
        <rect x="10" y="26" width="60" height="40" rx="4" fill="rgba(43,71,236,0.07)" />
        <rect x="10" y="72" width="44" height="5" rx="2.5" fill="rgba(43,71,236,0.14)" />
        <rect x="10" y="84" width="32" height="5" rx="2.5" fill="rgba(43,71,236,0.08)" />
        <rect x="10" y="100" width="40" height="20" rx="9" fill="rgba(43,71,236,0.16)" />
      </g>

      <g class="svc-illus-float">
        <rect width="280" height="192" rx="8" stroke="rgba(43,71,236,0.28)" stroke-width="0.5" />
        <rect x="10" y="10" width="240" height="24" rx="4" fill="rgba(43,71,236,0.12)" />
        <circle cx="20" cy="22" r="3" fill="rgba(43,71,236,0.2)" />
        <circle cx="30" cy="22" r="3" fill="rgba(43,71,236,0.12)" />
        <circle cx="40" cy="22" r="3" fill="rgba(43,71,236,0.12)" />
        <rect x="16" y="16" width="36" height="12" rx="3" fill="rgba(43,71,236,0.25)" />
        <rect x="180" y="17" width="18" height="10" rx="2" fill="rgba(43,71,236,0.1)" />
        <rect x="204" y="17" width="18" height="10" rx="2" fill="rgba(43,71,236,0.1)" />
        <rect x="228" y="17" width="18" height="10" rx="2" fill="rgba(43,71,236,0.1)" />
        <rect x="10" y="42" width="48" height="126" rx="4" fill="rgba(43,71,236,0.05)" stroke="rgba(43,71,236,0.1)" stroke-width="0.5" />
        <rect x="18" y="52" width="32" height="5" rx="2.5" fill="rgba(43,71,236,0.18)" />
        <rect x="18" y="64" width="24" height="4" rx="2" fill="rgba(43,71,236,0.1)" />
        <rect x="18" y="74" width="28" height="4" rx="2" fill="rgba(43,71,236,0.08)" />
        <rect x="18" y="84" width="20" height="4" rx="2" fill="rgba(43,71,236,0.08)" />
        <rect x="18" y="94" width="26" height="4" rx="2" fill="rgba(43,71,236,0.08)" />
        <rect x="66" y="42" width="184" height="36" rx="4" fill="rgba(43,71,236,0.06)" stroke="rgba(43,71,236,0.12)" stroke-width="0.5" />
        <rect x="76" y="52" width="72" height="6" rx="3" fill="rgba(43,71,236,0.18)" />
        <rect x="76" y="64" width="48" height="5" rx="2.5" fill="rgba(43,71,236,0.1)" />
        <rect x="66" y="86" width="88" height="52" rx="4" fill="rgba(43,71,236,0.08)" stroke="rgba(43,71,236,0.12)" stroke-width="0.5" />
        <rect x="74" y="118" width="12" height="12" rx="2" fill="rgba(43,71,236,0.15)" class="svc-illus-bar" />
        <rect x="90" y="110" width="12" height="20" rx="2" fill="rgba(43,71,236,0.22)" class="svc-illus-bar svc-illus-bar--2" />
        <rect x="106" y="114" width="12" height="16" rx="2" fill="rgba(43,71,236,0.18)" class="svc-illus-bar svc-illus-bar--3" />
        <rect x="122" y="106" width="12" height="24" rx="2" fill="rgba(43,71,236,0.25)" class="svc-illus-bar svc-illus-bar--4" />
        <rect x="162" y="86" width="88" height="24" rx="4" fill="rgba(43,71,236,0.06)" stroke="rgba(43,71,236,0.1)" stroke-width="0.5" />
        <rect x="162" y="116" width="88" height="22" rx="4" fill="rgba(43,71,236,0.05)" stroke="rgba(43,71,236,0.08)" stroke-width="0.5" />
        <rect x="66" y="146" width="184" height="22" rx="4" fill="rgba(43,71,236,0.04)" stroke="rgba(43,71,236,0.08)" stroke-width="0.5" />
        <rect x="76" y="154" width="60" height="5" rx="2.5" fill="rgba(43,71,236,0.12)" />
        <rect x="10" y="174" width="240" height="6" rx="3" fill="rgba(43,71,236,0.08)" />
      </g>

      <g class="svc-illus-float-delayed">
        <rect width="220" height="88" rx="8" stroke="rgba(43,71,236,0.22)" stroke-width="0.5" />
        <rect x="12" y="12" width="120" height="10" rx="3" fill="rgba(43,71,236,0.15)" />
        <rect x="12" y="30" width="186" height="10" rx="3" fill="rgba(43,71,236,0.07)" />
        <rect x="12" y="46" width="140" height="8" rx="3" fill="rgba(43,71,236,0.05)" />
        <rect x="12" y="62" width="72" height="14" rx="7" fill="rgba(43,71,236,0.2)" />
        <circle class="svc-illus-cursor" cx="196" cy="20" r="4" fill="rgba(43,71,236,0.35)" />
      </g>

      <g class="svc-illus-pulse">
        <rect width="56" height="28" rx="14" fill="rgba(43,71,236,0.12)" stroke="rgba(43,71,236,0.25)" stroke-width="0.5" />
        <circle cx="14" cy="14" r="5" fill="rgba(43,71,236,0.35)" />
        <rect x="26" y="10" width="22" height="8" rx="4" fill="rgba(43,71,236,0.2)" />
      </g>
    </svg>
  </div>
)}

{variant === 'ecommerce' && (
  <div class:list={['service-illustration', className]} aria-hidden="true">
    <svg class="eco-illus-svg" width="100%" viewBox="0 0 320 280" fill="none" xmlns="http://www.w3.org/2000/svg">
      <g opacity="0.04" stroke="#2B47EC" stroke-width="0.5">
        <line x1="0" y1="0" x2="0" y2="280" />
        <line x1="40" y1="0" x2="40" y2="280" />
        <line x1="80" y1="0" x2="80" y2="280" />
        <line x1="120" y1="0" x2="120" y2="280" />
        <line x1="160" y1="0" x2="160" y2="280" />
        <line x1="200" y1="0" x2="200" y2="280" />
        <line x1="240" y1="0" x2="240" y2="280" />
        <line x1="280" y1="0" x2="280" y2="280" />
        <line x1="320" y1="0" x2="320" y2="280" />
      </g>

      <g opacity="0.06">
        <circle cx="40" cy="250" r="50" stroke="#2B47EC" stroke-width="0.5" />
        <circle cx="40" cy="250" r="30" stroke="#2B47EC" stroke-width="0.5" />
      </g>

      <g transform="translate(20, 20)">
        <g class="eco-illus-product eco-illus-product--1 eco-illus-tbf">
          <rect width="85" height="110" rx="6" stroke="rgba(43,71,236,0.2)" stroke-width="0.5" />
          <rect x="8" y="8" width="69" height="55" rx="4" fill="rgba(43,71,236,0.08)" />
          <rect x="8" y="72" width="50" height="6" rx="3" fill="rgba(43,71,236,0.12)" />
          <rect x="8" y="84" width="30" height="8" rx="4" fill="rgba(43,71,236,0.18)" />
          <rect x="8" y="96" width="45" height="8" rx="4" fill="rgba(43,71,236,0.08)" />
          <rect class="eco-illus-select-ring" width="85" height="110" rx="6" fill="none" stroke="rgba(43,71,236,0.85)" stroke-width="1.25" />
        </g>

        <g transform="translate(95, 0)">
          <g class="eco-illus-product eco-illus-product--2 eco-illus-tbf">
            <rect width="85" height="110" rx="6" stroke="rgba(43,71,236,0.2)" stroke-width="0.5" />
            <rect x="8" y="8" width="69" height="55" rx="4" fill="rgba(43,71,236,0.1)" />
            <rect x="8" y="72" width="55" height="6" rx="3" fill="rgba(43,71,236,0.12)" />
            <rect x="8" y="84" width="35" height="8" rx="4" fill="rgba(43,71,236,0.18)" />
            <rect x="8" y="96" width="45" height="8" rx="4" fill="rgba(43,71,236,0.08)" />
            <rect class="eco-illus-select-ring" width="85" height="110" rx="6" fill="none" stroke="rgba(52,106,255,0.92)" stroke-width="1.25" />
          </g>
        </g>

        <g transform="translate(190, 0)">
          <g class="eco-illus-product eco-illus-product--3 eco-illus-tbf">
            <rect width="85" height="110" rx="6" stroke="rgba(43,71,236,0.2)" stroke-width="0.5" />
            <rect x="8" y="8" width="69" height="55" rx="4" fill="rgba(43,71,236,0.06)" />
            <rect x="8" y="72" width="45" height="6" rx="3" fill="rgba(43,71,236,0.12)" />
            <rect x="8" y="84" width="28" height="8" rx="4" fill="rgba(43,71,236,0.18)" />
            <rect x="8" y="96" width="45" height="8" rx="4" fill="rgba(43,71,236,0.08)" />
            <rect class="eco-illus-select-ring" width="85" height="110" rx="6" fill="none" stroke="rgba(43,71,236,0.88)" stroke-width="1.25" />
          </g>
        </g>
      </g>

      <g transform="translate(60, 150)">
        <g class="eco-illus-checkout eco-illus-tbf-check">
          <rect width="220" height="110" rx="8" stroke="rgba(43,71,236,0.25)" stroke-width="0.5" />
          <rect x="12" y="12" width="80" height="10" rx="3" fill="rgba(43,71,236,0.15)" />
          <line x1="12" y1="32" x2="208" y2="32" stroke="rgba(43,71,236,0.1)" stroke-width="0.5" />
          <rect x="12" y="42" width="140" height="6" rx="3" fill="rgba(43,71,236,0.07)" />
          <rect x="12" y="56" width="100" height="6" rx="3" fill="rgba(43,71,236,0.07)" />
          <rect x="170" y="42" width="38" height="20" rx="4" fill="rgba(43,71,236,0.12)" />
          <rect class="eco-illus-checkout-cta" x="12" y="82" width="196" height="16" rx="8" fill="rgba(43,71,236,0.18)" />
        </g>
      </g>

      <g class="eco-illus-pointer">
        <circle r="9" cx="0" cy="2" fill="#2B47EC" opacity="0.22" />
        <circle r="6" cx="0" cy="2" fill="#2B47EC" opacity="0.95" />
        <circle class="eco-illus-pointer-dot" r="2.25" cx="0" cy="2" fill="#1E35D4" opacity="1" />
      </g>
    </svg>
  </div>
)}

{variant === 'maintenance' && (
  <div class:list={['service-illustration', className]} aria-hidden="true">
    <svg class="maint-illus-svg" width="100%" viewBox="0 0 320 280" fill="none" xmlns="http://www.w3.org/2000/svg">
      <g opacity="0.04" stroke="#2B47EC" stroke-width="0.5">
        <line x1="0" y1="0" x2="0" y2="280" />
        <line x1="40" y1="0" x2="40" y2="280" />
        <line x1="80" y1="0" x2="80" y2="280" />
        <line x1="120" y1="0" x2="120" y2="280" />
        <line x1="160" y1="0" x2="160" y2="280" />
        <line x1="200" y1="0" x2="200" y2="280" />
        <line x1="240" y1="0" x2="240" y2="280" />
        <line x1="280" y1="0" x2="280" y2="280" />
        <line x1="320" y1="0" x2="320" y2="280" />
      </g>

      <g class="maint-illus-shield-wrap">
        <g transform="translate(110, 30)">
          <path
            d="M50 0 L100 20 L100 75 C100 110 50 140 50 140 C50 140 0 110 0 75 L0 20 Z"
            stroke="rgba(43,71,236,0.3)"
            stroke-width="0.5"
            fill="rgba(43,71,236,0.06)"
          />
          <path
            d="M30 70 L45 85 L72 55"
            stroke="rgba(43,71,236,0.4)"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            fill="none"
            class="maint-illus-check"
          />
        </g>
      </g>

      <g transform="translate(230, 20)" opacity="0.15">
        <g class="maint-illus-gear-spin">
          <circle cx="30" cy="30" r="20" stroke="#2B47EC" stroke-width="1" fill="none" />
          <circle cx="30" cy="30" r="8" stroke="#2B47EC" stroke-width="0.5" fill="rgba(43,71,236,0.1)" />
          <rect x="25" y="2" width="10" height="8" rx="2" fill="rgba(43,71,236,0.2)" />
          <rect x="25" y="50" width="10" height="8" rx="2" fill="rgba(43,71,236,0.2)" />
          <rect x="2" y="25" width="8" height="10" rx="2" fill="rgba(43,71,236,0.2)" />
          <rect x="50" y="25" width="8" height="10" rx="2" fill="rgba(43,71,236,0.2)" />
        </g>
      </g>

      <g class="maint-illus-panel-wrap">
        <g transform="translate(30, 160)">
          <rect width="260" height="100" rx="8" stroke="rgba(43,71,236,0.2)" stroke-width="0.5" />
          <rect x="12" y="12" width="60" height="8" rx="3" fill="rgba(43,71,236,0.15)" />

          <polyline
            class="maint-illus-chart"
            points="12,60 40,55 70,58 100,45 130,48 160,42 190,44 220,38 248,40"
            stroke="rgba(43,71,236,0.35)"
            stroke-width="1.5"
            fill="none"
            stroke-linecap="round"
            stroke-linejoin="round"
            pathLength="100"
          />

          <rect x="12" y="76" width="40" height="14" rx="7" fill="rgba(43,71,236,0.12)" />
          <rect x="60" y="76" width="50" height="14" rx="7" fill="rgba(43,71,236,0.08)" />
          <rect x="118" y="76" width="45" height="14" rx="7" fill="rgba(43,71,236,0.08)" />
        </g>
      </g>

      <g class="maint-illus-rings-bg" opacity="0.06">
        <circle cx="280" cy="130" r="45" stroke="#2B47EC" stroke-width="0.5" />
        <circle cx="280" cy="130" r="25" stroke="#2B47EC" stroke-width="0.5" />
      </g>
    </svg>
  </div>
)}

<style>
  .service-illustration {
    position: relative;
    width: min(100%, 520px);
    max-width: 100%;
    margin-inline: auto;
    pointer-events: none;
    opacity: 0.9;
  }

  @keyframes svc-illus-float {
    0%,
    100% {
      transform: translate(48px, 52px);
    }
    50% {
      transform: translate(48px, 46px);
    }
  }

  @keyframes svc-illus-float-slow {
    0%,
    100% {
      transform: translate(4px, 8px);
    }
    50% {
      transform: translate(4px, 2px);
    }
  }

  @keyframes svc-illus-float-delayed {
    0%,
    100% {
      transform: translate(108px, 228px);
    }
    50% {
      transform: translate(108px, 222px);
    }
  }

  @keyframes svc-illus-pulse {
    0%,
    100% {
      opacity: 0.7;
    }
    50% {
      opacity: 1;
    }
  }

  @keyframes svc-illus-ring {
    0%,
    100% {
      transform: scale(1);
      opacity: 0.06;
    }
    50% {
      transform: scale(1.03);
      opacity: 0.1;
    }
  }

  @keyframes svc-illus-cursor {
    0%,
    100% {
      opacity: 0.25;
    }
    50% {
      opacity: 0.55;
    }
  }

  @keyframes svc-illus-bar-grow {
    0%,
    100% {
      transform: scaleY(0.92);
      transform-origin: bottom;
    }
    50% {
      transform: scaleY(1);
      transform-origin: bottom;
    }
  }

  .svc-illus-float {
    animation: svc-illus-float 7s var(--ease-spring) infinite;
  }

  .svc-illus-float-slow {
    animation: svc-illus-float-slow 9s var(--ease-spring) infinite;
  }

  .svc-illus-float-delayed {
    animation: svc-illus-float-delayed 8s var(--ease-spring) infinite;
    animation-delay: 0.8s;
  }

  .svc-illus-pulse {
    transform: translate(338px, 148px);
    animation: svc-illus-pulse 4s ease-in-out infinite;
  }

  .svc-illus-rings circle:nth-child(1) {
    transform-origin: 350px 48px;
    animation: svc-illus-ring 10s ease-in-out infinite;
  }

  .svc-illus-rings circle:nth-child(2) {
    transform-origin: 350px 48px;
    animation: svc-illus-ring 10s ease-in-out infinite;
    animation-delay: 0.4s;
  }

  .svc-illus-rings circle:nth-child(3) {
    transform-origin: 350px 48px;
    animation: svc-illus-ring 10s ease-in-out infinite;
    animation-delay: 0.8s;
  }

  .svc-illus-cursor {
    animation: svc-illus-cursor 2.5s ease-in-out infinite;
  }

  .svc-illus-bar {
    animation: svc-illus-bar-grow 3s ease-in-out infinite;
  }

  .svc-illus-bar--2 {
    animation-delay: 0.2s;
  }

  .svc-illus-bar--3 {
    animation-delay: 0.4s;
  }

  .svc-illus-bar--4 {
    animation-delay: 0.6s;
  }

  /* Ecommerce hero — simula elegir cada producto (cursor + resaltado + carrito). */
  .eco-illus-svg {
    overflow: visible;
  }

  .eco-illus-tbf,
  .eco-illus-tbf-check {
    transform-box: fill-box;
    transform-origin: center center;
  }

  .eco-illus-select-ring {
    opacity: 0;
    vector-effect: non-scaling-stroke;
  }

  @keyframes eco-illus-product-pick {
    0%,
    5.5% {
      transform: scale(1);
    }
    6.5%,
    17% {
      transform: scale(1.036);
    }
    18.5%,
    100% {
      transform: scale(1);
    }
  }

  @keyframes eco-illus-select-ring {
    0%,
    5.5% {
      opacity: 0;
      stroke-width: 1.25;
    }
    6.5%,
    17% {
      opacity: 1;
      stroke-width: 1.55;
    }
    18.5%,
    100% {
      opacity: 0;
      stroke-width: 1.25;
    }
  }

  /* 9s = tres productos, ~3 s cad uno */
  .eco-illus-product--1 {
    animation: eco-illus-product-pick 9s cubic-bezier(0.4, 0, 0.2, 1) infinite both;
  }
  .eco-illus-product--1 .eco-illus-select-ring {
    animation: eco-illus-select-ring 9s cubic-bezier(0.4, 0, 0.2, 1) infinite both;
  }

  .eco-illus-product--2 {
    animation: eco-illus-product-pick 9s cubic-bezier(0.4, 0, 0.2, 1) infinite both;
    animation-delay: 3s;
  }
  .eco-illus-product--2 .eco-illus-select-ring {
    animation: eco-illus-select-ring 9s cubic-bezier(0.4, 0, 0.2, 1) infinite both;
    animation-delay: 3s;
  }

  .eco-illus-product--3 {
    animation: eco-illus-product-pick 9s cubic-bezier(0.4, 0, 0.2, 1) infinite both;
    animation-delay: 6s;
  }
  .eco-illus-product--3 .eco-illus-select-ring {
    animation: eco-illus-select-ring 9s cubic-bezier(0.4, 0, 0.2, 1) infinite both;
    animation-delay: 6s;
  }

  /* Centros locales al grid tras translate(20,20): 42.5,55 • global x +20, y +23 para el “tap” visual */
  @keyframes eco-illus-pointer-move {
    0%,
    30% {
      transform: translate(62.5px, 78px);
    }
    32%,
    62% {
      transform: translate(157.5px, 78px);
    }
    64%,
    94% {
      transform: translate(252.5px, 78px);
    }
    96%,
    100% {
      transform: translate(62.5px, 78px);
    }
  }

  @keyframes eco-illus-pointer-tap {
    0%,
    31% {
      transform: scaleY(1) scaleX(1);
    }
    33% {
      transform: scaleY(0.86) scaleX(0.86);
    }
    34% {
      transform: scaleY(1) scaleX(1);
    }
    62% {
      transform: scaleY(1);
    }
    64% {
      transform: scaleY(0.86) scaleX(0.86);
    }
    65% {
      transform: scaleY(1);
    }
    93% {
      transform: scaleY(1);
    }
    95% {
      transform: scaleY(0.86) scaleX(0.86);
    }
    96% {
      transform: scaleY(1);
    }
    100% {
      transform: scaleY(1);
    }
  }

  /* Estado sin animación: puntero sobre la primera tarjeta */
  .eco-illus-pointer {
    transform: translate(62.5px, 78px);
    animation: eco-illus-pointer-move 9s cubic-bezier(0.45, 0, 0.2, 1) infinite both;
  }

