---
/**
 * Miniatura 16:10. Usa el WebP original en /public/assets/projects/{imageBase}.webp
 * (no depende de la carpeta `generated/`). Ejecuta `pnpm run images:projects` si quieres
 * variantes extra para optimización futura.
 */
interface Props {
  imageBase: string;
  alt: string;
  class?: string;
}
const { imageBase, alt, class: className = '' } = Astro.props;
const src = `/assets/projects/${imageBase}.webp`;
---
<div
  class:list={[
    'relative aspect-[16/10] overflow-hidden bg-(--color-bg-surface)',
    className,
  ]}
>
  <img
    src={src}
    alt={alt}
    width={1000}
    height={625}
    loading="lazy"
    decoding="async"
    class="absolute inset-0 h-full w-full object-cover transition-transform duration-300 group-hover:scale-[1.02]"
  />
</div>
