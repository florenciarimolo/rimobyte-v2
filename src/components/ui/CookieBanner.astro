---
const STORAGE_KEY = 'rimobyte_cookie_consent_v1';
---

<div
  id="cookie-banner"
  class="cookie-banner pointer-events-none fixed bottom-0 left-0 right-0 z-10001 flex justify-center p-4 pb-[max(1rem,env(safe-area-inset-bottom))] md:p-6 md:pb-[max(1.5rem,env(safe-area-inset-bottom))]"
  role="region"
  aria-label="Aviso sobre cookies"
  aria-hidden="true"
  hidden
>
  <div
    class="pointer-events-auto w-full max-w-2xl rounded-[14px] border border-border-default bg-bg-surface/95 px-4 py-4 panel-shadow backdrop-blur-md md:flex md:max-w-3xl md:items-center md:justify-between md:gap-6 md:px-6 md:py-5"
  >
    <p class="m-0 text-[0.8125rem] leading-relaxed text-text-secondary md:flex-1">
      Usamos cookies necesarias y, al enviar el formulario de contacto, tecnología de Google (reCAPTCHA). Al continuar, aceptas su uso según nuestra{' '}
      <a href="/politica-cookies/" class="text-blue underline underline-offset-2 hover:text-blue-hover transition-colors">
        política de cookies
      </a>{' '}
      y la{' '}
      <a href="/politica-privacidad/" class="text-blue underline underline-offset-2 hover:text-blue-hover transition-colors">
        política de privacidad
      </a>.
    </p>
    <div class="mt-4 flex shrink-0 flex-wrap items-center gap-3 md:mt-0">
      <button
        type="button"
        id="cookie-banner-accept"
        class="btn btn-primary"
      >
        Entendido
      </button>
    </div>
  </div>
</div>

<script is:inline define:vars={{ STORAGE_KEY }}>
  (function () {
    const banner = document.getElementById('cookie-banner');
    const acceptBtn = document.getElementById('cookie-banner-accept');
    if (!banner || !acceptBtn) return;

    try {
      if (localStorage.getItem(STORAGE_KEY)) return;
    } catch {
      return;
    }

    banner.removeAttribute('hidden');
    banner.setAttribute('aria-hidden', 'false');

    acceptBtn.addEventListener('click', () => {
      try {
        localStorage.setItem(STORAGE_KEY, new Date().toISOString());
      } catch {
        /* ignore quota / private mode */
      }
      banner.setAttribute('hidden', '');
      banner.setAttribute('aria-hidden', 'true');
    });
  })();
</script>
