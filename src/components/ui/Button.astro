---
interface Props {
  href?: string;
  variant?: 'primary' | 'outline' | 'ghost';
  class?: string;
  type?: 'button' | 'submit';
  block?: boolean;
  external?: boolean;
}
const { href, variant = 'primary', class: cls = '', type = 'button', block = false, external = false } = Astro.props;

const variantClass = {
  primary: 'btn btn-primary',
  outline: 'btn btn-outline',
  ghost: 'btn btn-ghost',
}[variant];

const classes = [variantClass, block && 'btn--block', cls].filter(Boolean);
---
{href
  ? (
    <a
      href={href}
      class:list={classes}
      target={external ? '_blank' : undefined}
      rel={external ? 'noopener noreferrer' : undefined}
    >
      <slot />
    </a>
  )
  : <button type={type} class:list={classes}><slot /></button>
}
