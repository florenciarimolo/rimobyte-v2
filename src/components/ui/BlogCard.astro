---
interface Props {
  slug: string;
  title: string;
  description: string;
  date: Date;
  type: 'seo' | 'conversion' | 'nicho';
  readingTime: string;
}

const { slug, title, description, date, type, readingTime } = Astro.props;

const typeLabels: Record<string, string> = {
  seo: 'GUÍA',
  conversion: 'OPINIÓN',
  nicho: 'SECTOR',
};

const formattedDate = date.toLocaleDateString('es-ES', {
  day: 'numeric',
  month: 'short',
  year: 'numeric',
});
---

<a
  href={`/blog/${slug}/`}
  class="surface-card reveal group flex flex-col gap-4 no-underline text-inherit"
>
  <div
    class="flex items-center gap-2 font-mono text-[0.625rem] tracking-[0.14em] uppercase text-text-muted"
  >
    <span class="text-blue">{typeLabels[type]}</span>
    <span class="opacity-40">·</span>
    <span>{formattedDate}</span>
  </div>

  <h3
    class="headline-gradient font-display font-medium text-[clamp(1.375rem,2.2vw,1.625rem)] leading-[1.2] tracking-[-0.02em] m-0"
  >
    {title}
  </h3>

  <p class="font-body text-[0.9375rem] leading-[1.7] text-text-secondary m-0">
    {description}
  </p>

  <span
    class="mt-auto font-mono text-[0.625rem] tracking-[0.12em] uppercase text-text-muted inline-flex items-center gap-1 transition-[gap,color] duration-200 group-hover:text-blue group-hover:gap-2"
  >
    {readingTime} de lectura <span aria-hidden="true">→</span>
  </span>
</a>
