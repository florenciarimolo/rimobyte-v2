---
import BlogCoverVisual from './BlogCoverVisual.astro';
import Icon from './Icon.astro';
import { formatBlogDate, type BlogType } from '../../data/blogMeta';

interface Props {
  slug: string;
  coverImage: string;
  title: string;
  description: string;
  date: Date;
  type: BlogType;
  readingTime: string;
}

const { slug, coverImage, title, description, date, type, readingTime } = Astro.props;
const formattedDate = formatBlogDate(date);
---

<a
  href={`/blog/${slug}/`}
  class="blog-article-card reveal"
  data-blog-type={type}
>
  <BlogCoverVisual
    slug={slug}
    coverImage={coverImage}
    title={title}
    type={type}
    variant="card"
  />
  <div class="blog-article-info">
    <div class="blog-meta-row">
      <span>{formattedDate}</span>
      <span class="dot-sep" aria-hidden="true"></span>
      <span>{readingTime} de lectura</span>
    </div>
    <h3>{title}</h3>
    <p>{description}</p>
    <span class="blog-read-link">
      Leer artículo
      <Icon name="arrow-right" class="inline-flex size-3 [&_svg]:size-full" />
    </span>
  </div>
</a>
