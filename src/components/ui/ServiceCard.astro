---
import Icon from './Icon.astro';
import type { IconName } from './icons/registry';

interface Props {
  icon: IconName;
  title: string;
  body: string;
  price: string;
  href: string;
  class?: string;
}

const { icon, title, body, price, href, class: cls = '' } = Astro.props;
---

<article class:list={['landing-service-card reveal', cls]}>
  <div class="landing-service-card__graphic" aria-hidden="true">
    <Icon name={icon} class="landing-service-card__icon" />
  </div>
  <h3>{title}</h3>
  <p>{body}</p>
  <footer class="landing-service-card__foot">
    <span class="landing-service-card__price">{price}</span>
    <a href={href} class="landing-service-card__link">Saber más →</a>
  </footer>
</article>
