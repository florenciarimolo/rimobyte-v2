---
import Icon from './Icon.astro';
import type { IconName } from './icons/registry';
import Button from './Button.astro';

interface Props {
  icon: IconName;
  title: string;
  body: string;
  price: string;
  href: string;
  class?: string;
}

const { icon, title, body, price, href, class: cls = '' } = Astro.props;
---

<article class:list={['surface-card reveal group feature-card service-card', cls]}>
  <span class="service-card__watermark" aria-hidden="true">
    <Icon name={icon} class="service-card__watermark-icon" />
  </span>

  <div class="service-card__content">
    <Icon name={icon} class="service-card__icon" />
    <h3 class="service-card__title">{title}</h3>
    <p class="service-card__body">{body}</p>
    <div class="service-card__footer">
      <span class="service-card__price">{price}</span>
      <Button href={href} variant="ghost">Saber más →</Button>
    </div>
  </div>
</article>
