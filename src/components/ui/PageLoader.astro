---
/** Pantalla de carga inicial — símbolo RimoByte: gris → degradado marca por pasos */
---

<div
  id="page-loader"
  class="page-loader"
  role="status"
  aria-live="polite"
  aria-label="Cargando"
>
  <div class="page-loader__inner">
    <div class="page-loader__glow" aria-hidden="true"></div>
    <div class="page-loader__ring" aria-hidden="true"></div>
    <div id="page-loader-symbol" class="page-loader__symbol" aria-hidden="true"></div>
  </div>
</div>

<script is:inline>
  (function () {
    var loader = document.getElementById('page-loader');
    var sym = document.getElementById('page-loader-symbol');
    if (!loader || !sym) return;

    var MIN_MS = 900;
    var MAX_MS = 4500;
    var start = performance.now();
    var done = false;
    var colorInterval = null;

    var GREY = '#5C5C6E';
    var BRAND = ['#196BEE', '#6535E5', '#E715D1'];

    function hexToRgb(hex) {
      var n = hex.replace('#', '');
      return [
        parseInt(n.slice(0, 2), 16),
        parseInt(n.slice(2, 4), 16),
        parseInt(n.slice(4, 6), 16),
      ];
    }

    function rgbToHex(r, g, b) {
      return (
        '#' +
        [r, g, b]
          .map(function (x) {
            var s = Math.max(0, Math.min(255, x)).toString(16);
            return s.length === 1 ? '0' + s : s;
          })
          .join('')
      );
    }

    function mixHex(from, to, t) {
      var A = hexToRgb(from);
      var B = hexToRgb(to);
      return rgbToHex(
        Math.round(A[0] + (B[0] - A[0]) * t),
        Math.round(A[1] + (B[1] - A[1]) * t),
        Math.round(A[2] + (B[2] - A[2]) * t),
      );
    }

    /** t en [0,1]: mezcla gris → colores del logo */
    function applyLoaderColors(t) {
      sym.style.setProperty('--loader-c1', mixHex(GREY, BRAND[0], t));
      sym.style.setProperty('--loader-c2', mixHex(GREY, BRAND[1], t));
      sym.style.setProperty('--loader-c3', mixHex(GREY, BRAND[2], t));
    }

    var STEPS = 22;
    var HOLD_STEPS = 4;
    var CYCLE_LEN = STEPS + HOLD_STEPS + STEPS + HOLD_STEPS;
    var phase = 0;
    var TICK_MS = 85;
    var reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (!reduceMotion) {
      applyLoaderColors(0);
      colorInterval = window.setInterval(function () {
        if (done || loader.classList.contains('is-done')) return;
        phase = (phase + 1) % CYCLE_LEN;
        var t;
        if (phase < STEPS) {
          t = phase / (STEPS - 1);
        } else if (phase < STEPS + HOLD_STEPS) {
          t = 1;
        } else if (phase < STEPS + HOLD_STEPS + STEPS) {
          var back = phase - (STEPS + HOLD_STEPS);
          t = 1 - back / (STEPS - 1);
        } else {
          t = 0;
        }
        applyLoaderColors(t);
      }, TICK_MS);
    } else {
      applyLoaderColors(1);
    }

    function finish() {
      if (done) return;
      done = true;
      if (colorInterval !== null) {
        window.clearInterval(colorInterval);
        colorInterval = null;
      }
      applyLoaderColors(1);
      var wait = Math.max(0, MIN_MS - (performance.now() - start));
      setTimeout(function () {
        loader.classList.add('is-done');
        document.body.classList.remove('is-loading');
        setTimeout(function () {
          loader.remove();
        }, 550);
      }, wait);
    }

    if (document.readyState === 'complete' || document.readyState === 'interactive') {
      finish();
    } else {
      document.addEventListener('DOMContentLoaded', finish, { once: true });
      window.addEventListener('load', finish, { once: true });
    }
    setTimeout(finish, MAX_MS);
  })();
</script>

<style>
  .page-loader {
    position: fixed;
    top: calc(-1 * env(safe-area-inset-top, 0px));
    right: calc(-1 * env(safe-area-inset-right, 0px));
    bottom: calc(-1 * env(safe-area-inset-bottom, 0px));
    left: calc(-1 * env(safe-area-inset-left, 0px));
    width: auto;
    height: auto;
    min-height: calc(
      100lvh + env(safe-area-inset-top, 0px) + env(safe-area-inset-bottom, 0px)
    );
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-bg-base);
    transition:
      opacity 0.55s var(--ease-spring),
      visibility 0.55s var(--ease-spring);
  }

  .page-loader.is-done {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
  }

  .page-loader__inner {
    position: relative;
    width: 5.5rem;
    height: 5.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Degradado (posición animada); colores vía JS --loader-c* */
  .page-loader__symbol {
    position: relative;
    z-index: 1;
    width: 4.25rem;
    height: 4.25rem;
    --loader-c1: #5c5c6e;
    --loader-c2: #5c5c6e;
    --loader-c3: #5c5c6e;
    background: linear-gradient(
      135deg,
      var(--loader-c1) 0%,
      var(--loader-c2) 38%,
      var(--loader-c3) 72%,
      var(--loader-c1) 100%
    );
    background-size: 280% 280%;
    -webkit-mask-image: url('/favicon.svg');
    mask-image: url('/favicon.svg');
    -webkit-mask-size: contain;
    mask-size: contain;
    -webkit-mask-repeat: no-repeat;
    mask-repeat: no-repeat;
    -webkit-mask-position: center;
    mask-position: center;
    animation:
      loader-gradient 2.4s ease-in-out infinite,
      loader-breathe 2.5s ease-in-out infinite;
  }

  .page-loader__glow {
    position: absolute;
    inset: -40%;
    border-radius: 50%;
    background: radial-gradient(
      circle,
      rgba(101, 53, 229, 0.28) 0%,
      rgba(25, 107, 238, 0.12) 40%,
      transparent 70%
    );
    animation: loader-glow 2.4s ease-in-out infinite;
  }

  .page-loader__ring {
    position: absolute;
    inset: -8%;
    border-radius: 50%;
    border: 1px solid rgba(101, 53, 229, 0.2);
    animation: loader-ring 2.6s ease-in-out infinite;
  }

  @keyframes loader-gradient {
    0%,
    100% {
      background-position: 0% 50%;
    }
    50% {
      background-position: 100% 50%;
    }
  }

  /* Sin rotación: solo ligera pulsación de escala */
  @keyframes loader-breathe {
    0%,
    100% {
      transform: scale(1);
    }
    50% {
      transform: scale(1.05);
    }
  }

  @keyframes loader-glow {
    0%,
    100% {
      opacity: 0.55;
      transform: scale(0.92);
    }
    50% {
      opacity: 1;
      transform: scale(1.08);
    }
  }

  @keyframes loader-ring {
    0%,
    100% {
      transform: scale(1);
      opacity: 0.35;
    }
    50% {
      transform: scale(1.12);
      opacity: 0.7;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .page-loader__symbol,
    .page-loader__glow,
    .page-loader__ring {
      animation: none;
    }
    .page-loader {
      transition-duration: 0.15s;
    }
  }
</style>
