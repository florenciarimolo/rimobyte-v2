---
import Icon from './Icon.astro';

interface Props {
  /** glyph — comilla tipográfica · ornate — comillas curvas SVG */
  variant?: 'glyph' | 'ornate';
  /** lg / sm — glyph en cards · xl — ornate en caso destacado */
  size?: 'sm' | 'lg' | 'xl';
  /** subtle — watermark en cards · strong — caso destacado */
  tone?: 'subtle' | 'strong';
  class?: string;
}
const {
  variant = 'glyph',
  size = 'lg',
  tone = 'subtle',
  class: cls = '',
} = Astro.props;

const toneClass = tone === 'strong' ? 'opacity-[0.28]' : 'opacity-[0.06]';

const glyphSize =
  size === 'sm' ? 'text-[4.5rem]' : size === 'xl' ? 'text-[7rem]' : 'text-[5.5rem]';

const ornateSize =
  size === 'xl' ? 'w-[5.5rem] h-[4.25rem]' : size === 'sm' ? 'w-[3rem] h-[2.25rem]' : 'w-[4rem] h-[3rem]';
---

{variant === 'ornate' ? (
  <Icon
    name="quote-ornate"
    class:list={['block text-(--color-blue)', toneClass, ornateSize, cls]}
  />
) : (
  <span
    class:list={[
      'font-(--font-display) font-bold text-(--color-blue) leading-none select-none pointer-events-none',
      toneClass,
      glyphSize,
      cls,
    ]}
    aria-hidden="true"
  >"</span>
)}
