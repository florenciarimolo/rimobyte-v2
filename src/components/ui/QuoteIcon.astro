---
import Icon from './Icon.astro';

interface Props {
  /** glyph — comilla tipográfica · ornate — comillas curvas SVG */
  variant?: 'glyph' | 'ornate';
  /** xs / sm — cards compactas · lg — glyph · xl — ornate en caso destacado */
  size?: 'xs' | 'sm' | 'lg' | 'xl';
  /** subtle — watermark en cards · strong — caso destacado */
  tone?: 'subtle' | 'strong';
  class?: string;
}
const {
  variant = 'glyph',
  size = 'lg',
  tone = 'subtle',
  class: cls = '',
} = Astro.props;

const toneClass = tone === 'strong' ? 'opacity-[0.28]' : 'opacity-[0.06]';

const glyphSize =
  size === 'xs'
    ? 'text-[3rem]'
    : size === 'sm'
      ? 'text-[4.5rem]'
      : size === 'xl'
        ? 'text-[7rem]'
        : 'text-[5.5rem]';

const ornateSize =
  size === 'xl'
    ? 'w-[5.5rem] h-[4.25rem]'
    : size === 'lg'
      ? 'w-[4rem] h-[3rem]'
      : size === 'sm'
        ? 'w-[3rem] h-[2.25rem]'
        : size === 'xs'
          ? 'w-[2rem] h-[1.5rem]'
          : 'w-[4rem] h-[3rem]';
---

{variant === 'ornate' ? (
  <Icon
    name="quote-ornate"
    class:list={['block text-blue', toneClass, ornateSize, cls]}
  />
) : (
  <span
    class:list={[
      'font-display font-bold text-blue leading-none select-none pointer-events-none',
      toneClass,
      glyphSize,
      cls,
    ]}
    aria-hidden="true"
  >"</span>
)}
