---
/** Mockup de listado de inmuebles para landings sector inmobiliario (reutiliza estilos de carta). */
---

<div class="sector-menu-mockup">
  <div class="sector-menu-mockup__paper">
    <div class="sector-menu-mockup__header">
      <h4>
        Inmuebles <em>destacados</em>
      </h4>
      <p>Venta · Alquiler · Sincronizado con tu CRM</p>
    </div>

    <div class="sector-menu-mockup__section">
      <div class="sector-menu-mockup__section-label">En venta</div>
      <div class="sector-menu-mockup__item">
        <div class="sector-menu-mockup__item-name">
          Piso en Eixample
          <small>3 hab. · 98 m² · terraza</small>
        </div>
        <div class="sector-menu-mockup__item-dots" aria-hidden="true"></div>
        <div class="sector-menu-mockup__item-price">285.000€</div>
      </div>
      <div class="sector-menu-mockup__item">
        <div class="sector-menu-mockup__item-name">
          Ático con vistas
          <small>4 hab. · 142 m² · parking</small>
        </div>
        <div class="sector-menu-mockup__item-dots" aria-hidden="true"></div>
        <div class="sector-menu-mockup__item-price">495.000€</div>
      </div>
    </div>

    <div class="sector-menu-mockup__section">
      <div class="sector-menu-mockup__section-label">En alquiler</div>
      <div class="sector-menu-mockup__item">
        <div class="sector-menu-mockup__item-name">
          Piso reformado centro
          <small>2 hab. · 72 m² · amueblado</small>
        </div>
        <div class="sector-menu-mockup__item-dots" aria-hidden="true"></div>
        <div class="sector-menu-mockup__item-price">1.250€/mes</div>
      </div>
    </div>

    <div class="sector-menu-mockup__cta">Solicitar visita →</div>
  </div>
</div>
