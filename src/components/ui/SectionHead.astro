---
import Pill from './Pill.astro';

interface Props {
  title: string;
  titleEm?: string;
  titleGradient?: string;
  subtitle?: string;
  pill?: string;
  narrow?: boolean;
  class?: string;
}

const { title, titleEm, titleGradient, subtitle, pill, narrow = true, class: cls = '' } = Astro.props;
const gradientText = titleGradient ?? titleEm;
---

<header class:list={['section-head-v6', cls]}>
  {pill && <Pill text={pill} />}
  <h2>
    {title}
    {gradientText && (
      <>
        {' '}
        <span class="gradient-text">{gradientText}</span>
      </>
    )}
  </h2>
  {subtitle && (
    <p class:list={[narrow && 'max-w-[680px]']}>{subtitle}</p>
  )}
</header>
