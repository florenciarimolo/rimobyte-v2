---
interface Props {
  title: string;
  titleEm?: string;
  subtitle?: string;
  narrow?: boolean;
  class?: string;
}

const { title, titleEm, subtitle, narrow = true, class: cls = '' } = Astro.props;
---

<header class:list={['mb-[clamp(2.5rem,5vw,4rem)]', cls]}>
  <h2 class="font-display text-[clamp(1.75rem,3.5vw,2.5rem)] font-medium tracking-[-0.03em] mb-2 text-text-primary bg-none">
    {title}
    {titleEm && (
      <>
        {' '}
        <em class="font-normal italic text-gradient-logo">{titleEm}</em>
      </>
    )}
  </h2>
  {subtitle && (
    <p class:list={['text-text-secondary leading-[1.65]', narrow && 'max-w-[40ch]']}>{subtitle}</p>
  )}
</header>
