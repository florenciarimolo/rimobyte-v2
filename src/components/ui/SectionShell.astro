---
interface Props {
  id?: string;
  elevated?: boolean;
  class?: string;
  padding?: 'default' | 'none' | 'hero' | 'home';
  border?: boolean;
  transparent?: boolean;
  style?: string;
}

const {
  id,
  elevated = false,
  class: cls = '',
  padding = 'default',
  border = true,
  transparent = false,
  style,
} = Astro.props;

const paddingClass =
  padding === 'hero'
    ? 'pt-[clamp(7rem,13vw,11rem)] pb-[clamp(4rem,8vw,6rem)]'
    : padding === 'home'
      ? 'home-section'
      : padding === 'none'
        ? ''
        : 'py-[clamp(4rem,10vw,7rem)]';
---

<section
  id={id}
  style={style}
  class:list={[
    border && !transparent && 'border-b border-border-default',
    !transparent && (elevated ? 'bg-bg-elevated' : 'bg-bg-base'),
    transparent && 'bg-transparent',
    paddingClass,
    cls,
  ]}
>
  <slot />
</section>
