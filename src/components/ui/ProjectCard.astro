---
import type { Project, ProjectGridSpan } from '../../data/projects';
import { projectImageBase } from '../../data/projectImages';
import ProjectCardArrow from './ProjectCardArrow.astro';
import ProjectResultIcon from './ProjectResultIcon.astro';

interface Props {
  project: Project;
  gridSpan?: ProjectGridSpan;
}

const { project, gridSpan = project.gridSpan } = Astro.props;

const spanClass =
  gridSpan === 'featured'
    ? 'project-card-v6--featured'
    : gridSpan === 'span-6'
      ? 'project-card-v6--span-6'
      : 'project-card-v6--span-4';

const categoryAttr = project.categories.length > 0 ? project.categories.join(' ') : 'all';

const imageBase = projectImageBase(project.slug);
const srcset = imageBase
  ? `/assets/projects/generated/${imageBase}-w400.webp 400w, /assets/projects/generated/${imageBase}-w800.webp 800w`
  : undefined;
---

<div
  class:list={['project-card-v6-shell reveal', spanClass]}
  data-categories={categoryAttr}
>
  <a href={`/proyectos/${project.slug}/`} class="project-card-v6">
  <div
    class:list={[
      'project-card-v6__thumb',
      `project-card-v6__thumb--${project.thumbGradient}`,
    ]}
  >
    <img
      src={project.image}
      srcset={srcset}
      sizes="(min-width: 980px) 50vw, 100vw"
      alt={`Captura de la web ${project.name} — ${project.sector}`}
      class="project-card-v6__image"
      width="800"
      height="500"
      loading="lazy"
      decoding="async"
    />
    <div class="project-card-v6__thumb-shade" aria-hidden="true"></div>
    <span class="project-card-v6__meta">{project.eyebrow}</span>
    <span class="project-card-v6__url">{project.url}</span>
  </div>

  <div class="project-card-v6__content">
    <h3>{project.displayName}</h3>
    <p class="project-card-v6__summary">{project.cardSummary}</p>
    <div class="project-card-v6__result">
      <span class="project-card-v6__result-text">
        <ProjectResultIcon name={project.resultIcon} />
        <span class="gradient-text">{project.resultHighlight}</span>
      </span>
      <ProjectCardArrow />
    </div>
  </div>
  </a>
</div>
