---
import type { Project } from '../../data/projects';
import Eyebrow from './Eyebrow.astro';

interface Props {
  project: Project;
}

const { project } = Astro.props;

const challengeFirst =
  project.challenge.split('.')[0]?.trim() ?? project.challenge;
const challengeLead = challengeFirst.endsWith('.') ? challengeFirst : `${challengeFirst}.`;
---

<a href={`/proyectos/${project.slug}/`} class="project-card reveal group">
  <div class="project-card__media">
    <img
      src={project.image}
      alt={`Captura de la web ${project.name} — ${project.sector}`}
      width="720"
      height="540"
      loading="lazy"
      decoding="async"
    />
    <div class="project-card__hover-indicator" aria-hidden="true">
      <span class="font-mono text-[0.6875rem] tracking-[0.14em] uppercase text-text-primary">
        Ver caso →
      </span>
    </div>
  </div>

  <div class="project-card__content">
    <Eyebrow text={project.eyebrow} class="mb-3" />

    <h3 class="project-card__title">
      {project.displayName}
    </h3>

    <p class="project-card__summary">
      <strong>El desafío:</strong> {challengeLead}
      <strong> El resultado:</strong> {project.result}
    </p>
  </div>
</a>

<style>
  .project-card {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    text-decoration: none;
    color: inherit;
    cursor: pointer;
  }

  .project-card__media {
    position: relative;
    aspect-ratio: 4 / 3;
    border-radius: var(--radius-card);
    overflow: hidden;
    border: 1px solid var(--color-border-default);
    background: var(--color-bg-subtle);
    transition: border-color 0.3s var(--ease-spring);
  }

  .project-card:hover .project-card__media,
  .project-card:focus-visible .project-card__media {
    border-color: var(--color-border-blue);
  }

  .project-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    display: block;
    transition:
      transform 0.6s var(--ease-spring),
      filter 0.4s ease;
  }

  .project-card:hover .project-card__media img,
  .project-card:focus-visible .project-card__media img {
    transform: scale(1.03);
    filter: brightness(0.65);
  }

  .project-card__hover-indicator {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.3s var(--ease-spring);
    pointer-events: none;
  }

  .project-card:hover .project-card__hover-indicator,
  .project-card:focus-visible .project-card__hover-indicator {
    opacity: 1;
  }

  .project-card:focus-visible {
    outline: 2px solid var(--color-blue);
    outline-offset: 4px;
    border-radius: 4px;
  }

  .project-card__content {
    display: flex;
    flex-direction: column;
  }

  .project-card__title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1.375rem, 2.2vw, 1.625rem);
    line-height: 1.2;
    letter-spacing: -0.02em;
    background-image: var(--gradient-headline);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    margin: 0 0 1rem;
    transition: opacity 0.2s ease;
  }

  .project-card:hover .project-card__title,
  .project-card:focus-visible .project-card__title {
    opacity: 0.92;
  }

  .project-card__summary {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--color-text-secondary);
    margin: 0;
  }

  .project-card__summary strong {
    color: var(--color-text-primary);
    font-weight: 500;
  }
</style>
